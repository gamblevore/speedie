function string.OperatorPlus (|cstring| c, |string|)
	if self
		|| tmp = c.temp
		return self + (&tmp)|string|
	return c.wrap


function cstring.OperatorPlus (|string| s, |string|)
	if s
		|| tmp = .temp
		return (&tmp)|string| + s
	return .wrap


function string.OperatorPlus (|int64| i, |string|)
	opt norefcounts
	|| fs = faststring._Leaf
	|| n = (i < 0)|int|
	|| i2 = i
	while
		n++
		i2 /= 10
		loop i2
	
	fs.size = .length + n
	fs <~ self
	fs <~ i
	return fs
	

struct VirtualJBString // fakejbstring
	|int| Refcount
	|int| Length
	|&byte| Addr


libinternal cstring.temp (|VirtualJBString|)
	rz.refcount = 0
	rz.length = .length
	rz.addr = self|&byte|


function String.ExtractPathAndLine (|$ivec2| LineAndByte, |string|)
	if .LineCount > 1	
		|| parsed = .Parse
			|| isArg = (parsed == @arg)
			|| curr = (parsed.first (isarg) parsed)
			while curr
				|| pos = curr["pos"]
				|| path = curr["file"]
				path ?= curr["path"]
				if path and pos
					|int| n = pos.int // make the c++ compile D:
					LineAndByte = (1, n)
					return path.name
				curr++

	rz = .TrimStart("line ")
	|| tr = rz.trim
	if tr.isint
		|| v = (tr.int|int|, 0)
		LineAndByte = v
		return ""
	
	|| parts = rz / ':'
	rz = parts[0].trim
	|| v2 = (parts[1].trim.int|int|, parts[2].trim.int|int|) 
	LineAndByte = v2
	if rz[] == '~'
		rz = rz.AbsolutePath()


libinternal string.WrapSub (|int| MaxWidth, |bool| IsInline, |int| p, |int|)
	|| i		= p
	|| ParaMax	= 1K
	MaxWidth	= MaxWidth min Paramax
	|| Orig		= MaxWidth
	paramax += p

	while
		|| c = .Byte(i, -1)
		if c < 0
			return i
		if c|byte|.IsTextLine
			if !isinline
				return i + 1
			c = ' '
		if i >= ParaMax or MaxWidth <= 0
			return i

		if c == '\t'
			i++
			MaxWidth -= (Orig-MaxWidth).TabsWidth
		  elseif isinline
			i++
		  elseif CharSet.EditorSplitter[c]
			i++
			MaxWidth--
		  else									 // so where does the word end?
			|| WordEnd = .Find(CharSet.EditorSplitter, i, ParaMax)
				WordEnd += (self[WordEnd] > 32)
			  else
				WordEnd = .length min paramax
			|| MW2 = MaxWidth - .lengthutf8(i, WordEnd)
			if MW2 < 0
				if i == p
					i = p + MaxWidth
				return i
			MaxWidth = MW2
			i = WordEnd


libinternal String.TabsToSpacesSub (|faststring| fs)
	|| i = 0 
	for (c in self)
		if c == '\t'
			|| remain = 4 - (i mod 4)
			fs <~ (' ', remain)
			i += remain
	// what about line-endings?
		  else
			fs <~ c
			i++


function String.TabsToSpaces (|string|)
	|| fs = FastString()
	for (l.lines in self) (p)
		l.TabsToSpacesSub(fs)
		if p
			fs <~ self[p] // match line-ending
	return fs


function String.SpacesToTabs (|string|)
	|| fs = faststring()
	|| n = 0
	for line.lines in self
		if n++
			fs <~ '\n'
		|| SpaceCount = line.OutByte(' ') ?? line.Length
		if spacecount > 0
			fs <~ ('\t', SpaceCount >> 2)
			fs <~ (' ', spacecount&3)
		fs.AppendRange(line, spacecount, int.max)
	return fs
