


macro Print
	StrPrint_(_0.render)

macro PrintLine
	StrPrintLine_(_0.render)				// not self-referential anymore.

autogen StrPrint_ (|string?| data)
	cpp_wrapper JB_Str_Print

autogen StrPrintLine_ (|string?| data)		// ideally move this to string._printline
	cpp_wrapper JB_Str_PrintLine			// AND... make printline x use this.

inline Print (|string?| data)
	StrPrint_(data)

inline PrintLine (|string?| data=nil)
	StrPrintLine_(Data)						// to disambiguate vs macro



inline PrintLine (|Faststring!| data)
	cpp_part PrintFS
	StrPrintLine_(Data|string|)				// breaks cake
	data.Length = 0


function Print (|cstring?| data)
	cpp_wrapper JB_PrintCString


function ZalgoLine (|string| data, |float| Wierdness=8)
	printline data.zalgo(wierdness)

macro ZalgoLine
	Printline _0.render.zalgo


function Print (|object| o)
	cpp_name JB_Obj_Print
	print o.render


function PrintError (|string| data)
	cpp_wrapper JB_Str_PrintError


function byte.IsConso (|bool|)
	return .isletter and !.isvowel


function byte.IsVowel (|bool|)
	|| b = .lowercase
	return (b == 'a' or 'i' or 'e' or 'o' or 'u')


inline int.operatorof (|string| type, |string| nothing="", |string|)
	return type.Pluralize(self, nothing)


function string.Pluralize (|int| amount, |string| nothing="", |string|)
	cpp_part PluraliseAmount
	if !amount and nothing
		return nothing
		
	|| fs = FastString()
	if amount
		fs <~ amount
	  else
		fs <~ "no"
	fs <~ " "
	if amount == 1
		fs <~ self
	  else
		.Pluralize(fs)
	return fs


extend string
	render Pluralize (|bool| Plural=true)
		fs <~ self
		if Plural
			|| l = .last
			|| l2 = .last(1)
			//	'ch', 'sh', 'x', 's', 'z'
			if (l == 's' or 'x' or 'z') or (l == 'h'  and  l2 == 'c' or 's')
				fs <~ "e"
			fs <~ "s"


function string.Moat (|string|)
	opt norefcounts
	|| fs = faststring()
	fs.size = .length + 4
	fs <~ "__"
	fs <~ self
	fs <~ "__"
	return fs


function string.IsFileLike (|bool|)
    || c = self[]
    || c2 = self[1]
	if (c == '/') or ((c == '.' or c == '~') and ((c2 == '.') or (c2 == '/')))
		return true
	// so... we want to wrap to w... but prefer to wrap at a SPACE or comma
	
inline byte.IsTextLine (|bool|)
	if self == '\n' or '\r'
		return true

inline codepoint.IsTextLine (|bool|)
	if self == '\n' or '\r'
		return true

inline int.TabsWidth (|int|)
	return 4-(self & 3)


function String.UTF16To8 (|faststring|fs=nil, |int|BigEndian=1, |string|)
	cpp_wrapper JB_Str_UTF16To8


function String.UTF8 (|string|)
	if !.FindBadUTF8(0)
		return self
	return .UTF16To8


