

class SpdProcess (Process)
	linkage
		cpp_part Proc
	contains SpdProcess
	|jbin|						Writer
	|&pico|						Pico					
	|date|						LastSend
	|SpdMainFn|					SubProcess
	|[string]|					Params // move this to process?
	|int| 						DeathLimit
	|int|						DiedCount
	|bool|						IsParent

	constructor	(|string| path, |[string]| params=nil,  |SpdMainFn| fn=nil,  |bool| CaptureStdOut=false)
		super.constructor(path)
		
		.deathlimit = 12
		.pico = pico.new
		.pico.config.bits = 15
		.IsParent = path != "" or fn != nil
		.params	= params
		.SubProcess = fn
		.output = (faststring(), nil)(CaptureStdOut)
		.writer = FastString()
		
		if !.IsParent
			.pico.Completeexec
			app.BelongsToParent // should die if the parent dies!

			
	destructor
		.pico.destroy

	function IsOpen (|bool|)
		return self and .pico.socket

	helper Alive (|bool|)
		if self != nil
			return (.ChildAlive, .ParentAlive)(.IsParent)
	
	helper ParentAlive (|bool|)
		if app.ParentID > 1
			return true

	helper ChildAlive (|bool|)
		if .SubProcess
			return .IsOpen
		if .exit < 0
			return true
		if .pid > 0
			.ProcessExited


	syntax append (|string| str, |bool|)
		cpp_Part SendStr
		return self <~ (@sstr.msg(str))


	syntax append (|message| msg, |bool|)
		cpp_part Send 
		opt norefcounts
		debug_require msg
		
		if .pico.status
			msg.RenderJbin(.writer)
			if .pico.send(.writer)
				.LastSend = date.now
			.writer.length = 0
			.UpdatePipes
			
		if !.alive
			.Disconnect

 
	function Get (|float| T=0, |message|)
		opt norefcounts
		if self
			|| str = .pico.get(T)
				rz = str.parse
			.UpdatePipes
	
	
	function TimeWaitingForReply (|date|)
		|| last = .lastsend
		if .pico.config.lastread < last
			return last.ago

	
	function CheckDied
		if (.exit >= 0)
			.ProcessExited


	function Invalidate
		.Deathlimit = .diedcount
		.Diedcount++


	function CanActivate (|bool|)
		if .Diedcount < .Deathlimit
			return true
		error (.path, "Too many disconnections, blocking reconnection.")
	
	
	function ProcessExited
		if (.TermSig != 0)
			.DiedCount++
	        .pid = 0
		.Disconnect


	function IsDead (|bool|)
		return .termsig != 0

	
	helper Kill
		super.kill
		.Disconnect


	function ReadStdOut (|string|)
		if self
			.UpdatePipes
			return .Output
		

	syntax expect (|string| err)
		if .IsOpen
			printline err
			stderr.NewError(nil, err, .path)
		.Disconnect


	function Disconnect 
		.UpdatePipes
		.UnRegister
		.ClosePipes
		.pico.close


	helper StartProcess (|string| path, |[string]| Args=nil, |&pico| C = nil, |bool| CaptureStdOut, |bool|)
		cpp_Wrapper JB_Sh_StartProcess

	
	function RunChild (|bool|)
		debug_require .path
		if .CanActivate
			return .StartProcess(.path, .params, .pico /*!!nice!!*/, .output!=nil)


	function Activate (|bool|)
		if .IsOpen
			return true
		debug_require .IsParent
		if .pid
			debugger					// it has a PID but the socket was closed?
			.Kill						// just kill and restart it.
		if .CanActivate
			expect (.path) (self, "Can't re-activate process without a path.")
			return .RunChild


	function Run (fn_pth_wrap)
		return (.subprocess)(nil, 7) // 4 means thread, 1 + 2 = IDK.


	function RunMulti (fn_pth_wrap)
		return (.subprocess)(nil, 1)


	function SpdMainFn.Fill_CArgs (|[string]| p, |errorint|)
		|| sub_args = SpdProcess.CreateArgs("", p) #require
		return (self)(sub_args, 0)


	function SendCrashed
		opt norefcounts
		SpdProcess.StackTraceJbin(.writer, "crashed", 4)
		self <~ (.writer.getresult)


	iterator
		while .isopen
			|| s = .get
			if (!s) : exit
			yield s



	module
		InitOwner()
		|SpdProcess| Parent = nil
		
		function InitOwner
			if pico.HasParent
				.parent = SpdProcess("", nil, nil, false)
		
		target !minilib {
		helper TellParentIDied
			opt norefcounts
			visible
			cpp_name JB_ProcessReportCrash
			|| p = .parent
				p.SendCrashed
				p.disconnect
		}

		function CheckAllAlive
			opt norefcounts
			|| m = ProcessOwner.First
			while m
				|| ch = m
				m++
				if ch isa SpdProcess
					ch.Checkdied
		

		helper CreateArgs (|string| path, |[string]| Args, |&cstring|)
			cpp_wrapper


		function BackTrace (|&_voidptr| space, |&int| size, |&cstring|) 
			cpp_wrapper JB_BackTrace
		
		
		function StackTraceJbin (|jbin| j, |string| reason, |int| skip = 4)
			|_voidptr[32]| arr
			|| size = 32
			|| strs = BackTrace(&arr[0], &size)
			j <~ _JbinHeader
			j.enter(@arg, reason)
			for i in skip to size - 1
				j.AddCString(strs[i], @emb)
			memory.free(strs)


		function Child (|string| app_path, |[string]| params=[], |bool| CaptureStdOut=false, |SpdProcess|)
			debug_require params!=nil
			require app_path.file.mustexist
			rz = SpdProcess(app_path, params, nil, CaptureStdOut)
			if !rz.RunChild
				rz = nil


prototype fn_pth_wrap (|SpdProcess| Proc, |int|)
	function Start (|SpdProcess| Proc, |errorint|)
		cpp_wrapper JB_ThreadStart


prototype SpdDeathActionFn

prototype SpdMainFn	(|&cstring| args, |int| Mode, |ErrorInt|)
	function RunThreaded (|[string]| R = [],  |SpdProcess|)
		debug_require r!=nil
		rz = SpdProcess("", r, self)
		|| OK = .Fill_CArgs(rz.params) == 0
		if (SpdProcess.Run).Start(rz) != 0
			OK = false
		if !OK
			rz = nil



extend_module app
	function IsMainThread (|bool|)
		return !.IsntMainThread
	helper IsntMainThread (|bool|)
		cpp_wrapper JB_LibIsThreaded
	helper BelongsToParent (|int|)
		cpp_wrapper JB_App__BelongsToParent		
	helper SyntaxAppend (|SpdDeathActionFn| handler)
		cpp_Wrapper JB_App__AtExit

	function StartChild (|[string]| r, |SpdProcess|)
		return SpdProcess.Child(.path, r)
		
	helper ParentID (|pid_int|)
		cpp_wrapper JB_App__ParentID
		
	helper ID (|pid_int|)
		cpp_wrapper JB_App__ID
	

