		
class SpdProcess (Process)
	linkage
		cpp_part Proc
	contains SpdProcess
	|jbin|						Writer
	|&pico|						Pico
	|stringzeroterminated|		_DebugName
	|SpdMainFn|					SubProcess
	|int| 						DeathLimit
	|int|						DiedCount
	|bool|						WeAreParent
	|bool|						AlreadyWarnedDied
	|ProcessMode|				Mode

	constructor	(|string| path, |stringzeroterminated| DebugName, |[string]| params=nil,  |SpdMainFn| fn=nil,  |ProcessMode| Mode=ProcessMode.AutoPrintErrors)
		super.constructor(path) // <-- mode should be passed here
		
		.deathlimit = 12
		.WeAreParent = path != "" or fn != nil
		.params	= params
		.SubProcess = fn
		.mode = mode
		.output = (faststring(), nil)(.Mode is CaptureStdOut)
		.erroroutput = (faststring(), nil)(.mode is CaptureOrPrintErrors)
		.writer = FastString()
		.pico = (pico.new(debugname), pico.parent)(.WeAreParent)
		._DebugName = DebugName

			
	destructor
		.pico.destroy("destructor")
			
	function CommsOpen (|bool|)
		return self and .pico.status == 0

	helper Alive (|bool|)
		if self != nil
			return (.ChildAlive, .ParentAlive)(.WeAreParent)
	
	helper ParentAlive (|bool|)
		if app.ParentID > 1
			return true

	helper ChildAlive (|bool|)
		if .SubProcess
			return .CommsOpen
		if .exit == -1
			return true


	syntax append (|string| str, |bool|)
		cpp_Part SendStr
		return self <~ (@sstr.msg(str))


	syntax append (|message| msg, |bool|)
		cpp_part Send 
		opt norefcounts
		debug_require msg
			
		if .pico.status
			msg.RenderJbin(.writer)
			.pico <~ .writer
			.UpdatePipes

 
	function Get (|float| T=0, |message|)
		opt norefcounts
		if self
			.UpdatePipes
			|| str = .pico.get(T)
				rz = str.parse
	

	function LastSend (|date|)
		|| c = .pico.config
			return c.lastsend
		
	
	function TimeWaitingForReply (|date|)
		|| c = .pico.config
			|| last = c.lastsend
			if c.lastread < last
				return last.ago

	
	helper HandleDied
		|| OK = .status
		.DiedCount += !OK
		if (.ErrorOutput!=nil) and (.mode is AutoPrintErrors)
			printline .ErrorOutput
		.Disconnect(OK.signalname) // removes us from the check-list


	function CanActivate (|bool|)
		if .Diedcount < .Deathlimit
			.alreadywarneddied = false
			return true
		if !.AlreadyWarnedDied
			.AlreadyWarnedDied = true
			error (.path, "Too many disconnections, blocking reconnection.")
	
	
	helper Kill
		disabled "Explain why"
		
	helper Kill (|stringzeroterminated| why)
		super.kill
		.Disconnect(why)


	function ReadStdOut (|string|)
		if self
			.UpdatePipes
			return .Output
		

	syntax expect (|string| err)
		if .CommsOpen
			printline err
			stderr.NewError(nil, err, .path)
		.Disconnect(err)


	function Disconnect (|stringzeroterminated| Why="")
		opt norefcounts
		.UpdatePipes
		.UnRegister
		.ClosePipes
		if .pico
			if .alive and !why and .CommsOpen
				why = "UnknownReason"
				debugger
			.pico.close(Why)
			.pico = nil


	helper StartProcess (|string| path, |[string]| Args=nil, |&pico| C = nil, |bool| CaptureStdOut, |bool|)
		cpp_Wrapper JB_Sh_StartProcess

	
	function RunChild (|bool|)
		debug_require .path
		|| p = .pico init pico.new
		return .StartProcess(.path, .params, p, .output!=nil)


	function TimedOut (|date| Durr, |bool|)
		if (.TimeWaitingForReply > durr)
			error (self, "child timed out.")
			return true
	
	function IsOpen (|bool|)
		require self and .CommsOpen
		if .WeAreParent
			return .exit == -1
		return app.ParentID > 1
			
	function Deactivate
		|| ChAlive = .Exit == -1
		if .CommsOpen and !ChAlive	// inconsistant...
			.handledied				// disconnect comms
		if ChAlive
			.Kill("lost comms")		// kill child
	
	
	function ActivateChild (|bool|)
		if .isopen
			return true

		.Deactivate
		
		if .CanActivate
			expect (.path) (self, "Can't re-activate process without a path.")
			return .RunChild


	iterator
		while .pico.CanRead
			yield .get(1000)


	module
		InitOwner()
		|SpdProcess| Parent = nil
		
		function InitOwner
			target !minilib
				if pico.parent
					.parent = SpdProcess("", "")

		function CheckAllAlive
			opt norefcounts
			|| m = ProcessOwner.First
			while m
				|| ch = m
				m++
				if ch.exit >= 0
					if (ch isa SpdProcess)
						ch.HandleDied
					ch.UnRegister
		

		helper CreateArgs (|string| path, |[string]| Args, |&cstring|)
			cpp_wrapper


		function BackTrace (|&_voidptr| space, |&int| size, |&cstring|) 
			cpp_wrapper JB_App__BackTrace


		function RunChild (|string| app_path, |string| DebugName="", |[string]| params=[], |ProcessMode| Mode=ProcessMode.CaptureAll, |SpdProcess|)
			debug_require params!=nil
			require app_path.file.mustexist
			rz = SpdProcess(app_path, debugname, params, nil, Mode)
			if !rz.RunChild
				rz = nil


datatype ProcessMode (byte)
	flags
		CaptureStdOut
		CaptureOrPrintErrors = (CaptureErrors, AutoPrintErrors)
		CaptureAll = CaptureStdOut ||| AutoPrintErrors

	syntax is (|ProcessMode| M, |bool|)
		return self&M


prototype SpdMainFn	(|_voidptr| Obj, |&cstring| args, |&pico| Comms, |bool|)
	function RunThreaded (|[string]| R = [],  |SpdProcess|)
		|| c_args = SpdProcess.CreateArgs("", r) #require
		rz = SpdProcess("", "SpdMainFn()", r, self)
		if !rz.pico.startthread(self|picothreadfn|, 7|_voidptr|, c_args)
			rz = nil


prototype SpdDeathActionFn


function app.Fork (|[string]| r, |SpdProcess|)
	return SpdProcess.RunChild(.path, r)

