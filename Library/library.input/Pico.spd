

prototype PicoThreadFn (|&pico| Comms, |_voidptr| Obj, |&cstring| Args=nil, |bool|)



struct PicoMessage
	linkage: wrapper, cpp_part Pico
	|int|		Length
	|&char|		Data
	
	syntax cast (|bool|)
		return .data
	
	module
		function From (|string| s, |PicoMessage|)
			rz.length = s.length
			rz.data = s.addr|&char|
		function FromFS (|faststring| fs, |PicoMessage|)
			rz.length = fs.length
			rz.data = fs.ResultPtr|&char|


function @string.FromPico (|picomessage| M, |string|)
	|| x = m.data|&byte|
		return string.own(x, M.length)


struct Pico
	linkage: wrapper, cpp_part Pico, cpp_class PicoComms
		

	function CreateChild (|&pico|)
		cpp_wrapper PicoChild

	function Destroy
		cpp_wrapper PicoDestroy

	function IsParent (|bool|)
		cpp_wrapper PicoIsParent
		
	helper StartFork (|bool| Exec=false, |PID_Int|)
		cpp_wrapper PicoStartFork

	function StartThread (|PicoThreadFn| fn, |_voidptr|Obj, |&cstring|Args=nil, |bool|)
		cpp_wrapper PicoStartThread

	function CompleteExec (|bool|)
		cpp_wrapper PicoCompleteExec
	
	syntax append (|string| str, |bool| Wait=false, |bool|)
		cpp_part SendString
		return .send(picomessage.From(Str), wait)

	syntax append (|faststring| fs, |bool| Wait=false, |bool|)
		cpp_part SendFS
		return .send(picomessage.Fromfs(fs), wait)
		
	function Send (|PicoMessage| msg, |bool| Wait=false, |bool|)
		cpp_wrapper PicoSend

	function Config (|&PicoConfig|)
		cpp_wrapper PicoConf
	
	helper __Get (|float| T=0.0, |PicoMessage|)
		cpp_wrapper PicoGet

	function Get (|float| T=0.0, |string|)
		return string.FromPico(.__get(T))		

	function Close 
		cpp_wrapper PicoClose
	
	function Status (|ErrorInt|)
		cpp_wrapper PicoError

	function IsSending (|bool|)
		cpp_wrapper PicoStillSending
	
	function Fork (|&pico|)
		|| f = .startfork
		if f >= 0
			return self

	function SleepForSend
		while .issending
			app.sleep(0.001s)

	module
		|&pico| Parent_
		function HasParentSocket (|bool|)
			cpp_wrapper PicoHasParentSocket
		function DesiredThreadCount (assigns:|int| C, |bool|)
			cpp_wrapper PicoDesiredThreadCount
		function Create (|&pico|)
			cpp_wrapper PicoCreate

		function New  (|bool| IAmParent=true, |int| bits=16, |&pico|)
			if iamparent
				rz = pico.Create
			  else
				rz = pico.parent
			|| c = rz.config
			c.noise = -1 // for now!
			c.name = app.callpath.cstring.name
			if !c.name: c.name = "()"
			c.bits = bits
			
		function Parent (|&pico|)
			|| p = Parent_
				return p
			require .HasParentSocket
			rz = pico.new(false)
			Parent_ = rz
			rz.CompleteExec
	

struct PicoConfig
	linkage:wrapper
	|cstring|	Name
	|Date|		LastRead
	|int|		Noise
	|float|		SendTimeOut
	|int|		SendFailed
	|int|		ReadFailed
	|int|		QueueBytesRemaining
	|int|		Bits

	
