

class Task (RingTree)
	|&nil|				_Func
	|byte|				_ObjectCount
	|taskstate| 		State
	|int64[9]| 			_Local
	
	constructor (|&nil| fn, |int| Objs)
		._Func = fn
		._ObjectCount = Objs
	
	destructor
		for (i in ._ObjectCount|int|)
			jb_decr(._Local[i]|object|) // noice

	
datatype TaskState (byte)
	flags
		|TaskState| 
		Started
		Paused
		Finished
	syntax is (|TaskState| t, |bool|)
		return self & t

