

class Task (RingTree)
	|&nil|				_func
	|int64[9]| 			_local
	|byte|				_ObjectCount
	|taskstate| 		State
	
	constructor (|&nil| fn, |int| Objs)
		._Func = fn
		._ObjectCount = Objs
		for i in 9
			._local[i] = 0
	
	destructor
		for (i in ._ObjectCount|int|)
			jb_decr(._local[i]|object|) // noice

	
datatype TaskState (byte)
	flags
		|TaskState| 
		Started
		Paused
		HadErrors
		Successful
		Finished
	
	syntax is (|TaskState| t, |bool|)
		return self & t

