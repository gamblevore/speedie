

class Task (list)
	linkage
		visible
		cpp_class JB_Task

	|taskstate| 		State
	|byte|				_ObjectCount
	|&nil|				_func
	
	constructor
		._Func = &(message.dummy)
		._ObjectCount = 0
		
	destructor
		visible
		|| curr = ((&._func)|&object|) + 1
		for  i in ._ObjectCount|int|
			jb_decr( curr[i] )          // noice
	



datatype TaskState (byte)
	flags
		|TaskState| 
		Started
		Paused
		HadErrors
		Successful
		Finished
	
	syntax is (|TaskState| t, |bool|)
		return self & t

