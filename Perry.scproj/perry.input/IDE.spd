	function MyStatsMode (|int|)
		rz = perryide.StatsMode|int|
		if rz < 0
			rz = 3
		if rz > 3
			rz = 0
		perryide.StatsMode = rz
	
	
	function InfoStatus (|faststring|)
		opt norefcounts
		|| fs = .stats init FastString()
		|| i = .MyStatsMode
		|| e = .editme
		|| d = e.Document
		if i == 0
			.ExtraAppInfo(fs)		
		  elseif (i == 1)
			|| t = e.text

			fs <~ "Chars ${t.lengthutf8}   Lines ${e.wrappedlines.last!.vline}"
			|| msg = e.ParsedMessage
				|| loc = msg.LinesOfContent
				fs <~ "   LOC ${loc[0]}   Nodes ${loc[1]}"

			fs <~ (' ', 3)
			if t.IsASCII
				fs <~ "ASCII"
			  elseif t.FindBadUTF8
				fs <~ "binary"
			  else
				fs <~ "UTF-8"
				
			t = e.SelText
			if t.LengthUTF8 == 1
				fs <~ "   CP "
				fs <~ t.Codepoint(false	)
			
			if d
				if d.WasJbin
					fs <~ ".jbin"
				if d.WasCompressed
					fs <~ ".mz"

		  elseif i == 2
			|| f = .filelist.FirstSelected as filerow
				if f.asdir
					fs <~ f.Name
					fs <~ "/"
				  else
					fs <~ "proj"
					f = (.filelist.listsource as filerow)
			
			if f
				|| s = f.lastsize
					fs <~ " "
					s.StrSize(fs)
					fs <~ " in (${f.LastFileCount} \11)"
				  else
					fs.Length = 0
					if .IsEditingSource
						fs <~ "no source found"
					  else
						fs <~ .path
		
		  elseif i == 3
			|| img = GUI.screen.size.area * 4 * 2
			fs.strsize("Obj ", app.ObjMemory)
			fs.strsize("   Str ", app.stringmemory)
			fs.strsize("   Img ", app.OtherMemory+img)
			|| PS = PicoGlobalStats()
			fs <~ "   Sck ${PS.OpenSockets}/${PS.OpenPicos}"
		
		if d and d.InvalidJeebox
			fs <~ "  Invalid Jeebox!"

		return fs


	function faststring.StrSize (|string| name, |int64| S)
		self <~ name
		s.StrSize(self)
	
	
	function NextProjInfo
		perryide.StatsMode = perryide.StatsMode - keys.Shift.dir
		.ShowLeftStats


	function ShowLeftStats
		opt norefcounts
		.ProjectInfo.text = .InfoStatus	


	function ShowRightStats
		if .isgraphics
			(.charinfo isnt visible)
			return
		
		(.charinfo is visible)
		(.lineinfo is visible)
		|| fs = FastString()
		|| t = .Editme.Text
		|| sel0 = .editme.SelRange.x
		|| sel = .EditMe.SelText
		|| sel2 = sel
		if sel2.last.IsTextLine
			sel2 = sel2.Shorten(1)
		fs <~ "ln "
		fs <~ .editme.CurrLine
		|| n = sel2.count(charset.line)-1		// could probably remove this call to linecount
			fs <~ "+"				// just compare vlines within textviewline
			fs <~ n+1				// then its literally used in one place...
		.LineInfo.text = fs			// can just inline it
									// we could make a generic str.count(charset)... might be better than remove
		
		if .BytesInfoMode
			fs <~ "byte $sel0"
			n = sel.Length
		  else
			fs <~ "ch ${t.lengthutf8(0, sel0)}"
			n = sel.lengthutf8
		if n
			fs <~ "+"
			fs <~ n

		.charInfo.text = fs	

	
