	function Show (|bool| FromClick=false)
		disabled "use .ShowIDE"

	
	function ShowIDE (|bool| FromClick=false)
		debug_require self // what?
		|| p = .Project
		app.prefs["currproj"] = p
		|| rec = Perry.RecentProjects.Find(@tmp, p)
			rec.Parent.first = rec
		if FromClick
			if .islast
				.ClickedTodo
			  else
				.recheck
		if !.IsFront
			.ProjectTabs.selected = .SharedProjectTabSource
			.editme.SetFocus				// Make it simple
			super.show
		.id = .name
		GUI.Title = .id


	function UpdateSearchSwap (|textview|)
		opt norefcounts
		require .isfront
		|| E = .inline.editor
		|| M = .MassSearchField
		|| F = .realfocus
		if F == E
			return M
		if F == M
			return E
			
	
	function UpdateSearchText
		opt norefcounts
		|| other = .UpdateSearchSwap			#require
		|| rf = .RealFocus // what if they just used the same document??
			|| t = rf.text // sigh
			GUI.LastSearch = t
			if other.text != t
				other.text = t
				other.Selrange = 0


	function HideStuff 
		opt norefcounts
		|| M  = .MouSEXY
		|| LB = .ViewButtons.lastrect.y1
		|| LF = .filelist.lastrect.x2-2
		
		|| HideTop  = (m.y < LB)
		|| HideSide = (m.x > LF)
		|| HideTabs = HideTop or .IsTextMode
		|| VisSide  = !.filelist.decluttering
		|| VisTop   = !.RecentAndSplash.decluttering
		|| VisTabs  = !.ProjectTabs.Decluttering

		// OK... so .. if one is visible, we don't make the other invis
		if .filelist.cmm == .openedmenu
			hideside = false

		if VisSide and VisTop and (HideSide != HideTop)
			HideSide = false
			HideTop = false
			HideTabs = false
		
		require !.CurrMouseDown
		if HideTabs == VisTabs
			.ProjectTabs.decluttered = HideTabs
		if .IsTextMode
			.ProjectTabs.Declutterer.hide // not good enough? it should be made invisible?
			(.ProjectTabs isnt visible)
		  else
			(.ProjectTabs is visible)

			
		if (hidetop == vistop)
			.RecentAndSplash.decluttered = hidetop
			.ASMButton.Decluttered = Hidetop
			if HideTop
				(.DebugArgsText isnt visible)			// better to declutter
			|| ShowBuilders = !HideTop and (!.IsTextMode or .path.isspd)
			|| HideBuilders = !ShowBuilders
			.runbutton.decluttered		= HideBuilders
			.buildbutton.decluttered	= HideBuilders
			.Progress.Decluttered		= HideBuilders
		
		if (hideside == visside)
			.filelist.decluttered = hideside
			|| f = .Focus
			if HideSide and (!f or f.Decluttering)
				.editme.SetFocus
			if .viewing == .viewfiles
				.noneed
//				|| fl = .filelist.ListSource as filerow
//					fl.Name = "file".pluralize(fl.LastFileCount)
// 				// this isnt what we want to do.


	function CheckCrashed (|UnixProcess| p, |string| what, |bool|)
		require p
		|| Exit = p.Status
		if exit.killed
			return true
		if !exit.Crashed
			return false
		
		|| fs = faststring()
		fs <~ "Crashed: ${exit.name}  {${p.render}}\n"
		fs <~ p.ReadStdErr.FindStacktrace
		.Notify(fs, @emb + what)
		if p == .Compilr
			return .CancelCompile
		return true


	function string.FindStacktrace (|string|)
		|| f = "\n****** CRASH"
		|| where = .find(f)				#require
		where = .find("\n", where)		#require
		where += f.length
		|| After = .find("\n-----------------------\n", where)
		if !after: after = int.max
		
		return self[where, after]
		

	function FeedBackLivedTooLong (|spdprocess!| f, |bool|)
		|| Delay = 20.0
		target debug
			delay = 5.0
		delay += .position|float|
		|| D = delay.date
		if (f.lastsend.ago > D)
//			if app.yes("print")
//				printline f.lastsend.ago.float.render + " ago means death for " + f.pico.name
			return true
		
	
	function SaveMemory
		if .IsFront
			return
		require !.UsingSpdLib
		|| f = .Feedback
		if f.CommsOpen  and  .FeedBackLivedTooLong(f)
			.LogOneAction("Released Speedie: " + .name)
			f.Kill(0) // savememory
	
	
	behaviour FrameStep // perframe, eachframe, onframe
		.ProjectTabs.TrimWidth
		if GUIactive
			.SaveMemory
			if !.focus
				.setfocus(.editme) // shouldn't need this... why doesn't .focus setter get called?
		.UpdateDebuggedApp(false)

		if .CheckCrashed(.feedback, "feedback")
			.Feedback = nil
		if .CheckCrashed(.compilr,  "compiler")
			.Compilr = nil // not needed? checkcrashed clears it (via wierd logic)

		|| f = .Feedback
			.SpeedieMsgReceive(f)
		.UpdateSearchText
		.UpdateStatusErrors
		.ReadLog(false)
		.PopupDisplayFadeIn
		
		require .IsFront
		if ._FrameNum == 1			// once a second?
			require !.ProjClosed
		
		if .UpdateMem
			.ShowLeftStats
		
		if ._FrameNum == 1
			.CheckModified
		
		if GUIActive and !.DebugArgsText.HasFocus
			.HideStuff


	function UpdateMemOne (|int| i, |uint| c, |bool|)
		require .LastMemory[i] != c
		.LastMemory[i] = c
		return true
		
		
	function UpdateMem (|bool|)
		require perryide.StatsMode == 3
		rz |= .UpdateMemOne(0, app.ObjMemory)
		rz |= .UpdateMemOne(1, app.stringmemory)
		rz |= .UpdateMemOne(2, app.OtherMemory)


	function CheckModified 
		|| doc = .editme.Document
			doc.CheckModified
		

	function ProjClosed (|bool|)
		require .CanAskingAboutMissing
		|| f = .project
		require !f.exists
		.CanAskingAboutMissing = false
		
		if ("Project "+f.name+" isn't on the file-system anymore.\n\nWould you like to close it?").confirm
			.close
			rz = true
		  elseif .IsSingleFileProject
			f.write("") // why not f.touch?
				

	function ShowFind (|bool|)
		.retextsubfind
		.ViewAsProject
		.View(.ViewSearch)
		.MassSearchField.SelectAll
		.MassSearchField.SetFocus
		return true
	
	
	function Flip (|textview| s, |bool|)
		|| Item = .compiletabs.selected
		if item  and  .ProductSep.isopen  and item.obj == s
			.ProductSep.collapse
			return false
		.ShowText(s, nil, true)
		return true


	function ShowQuickStuff (|bool| FuncMenu, |bool|)
		if FuncMenu
			if (.FunctionMenu.MenuIsOpen)
				FuncMenu = false
		  else
			if (.filelist.QuickOpen is visible)
				FuncMenu = true
		if FuncMenu
			.FileList.quickopen isnt visible
			return .FunctionMenu.SearchMenu
			
		  else
			|| sub = .FunctionMenu.SubMenu
				sub.CloseMenu
			if .FileList.ShowQuickOpen
				return true
			return .FunctionMenu.SearchMenu
			
	
	function GotoIncludedFile (|string| path, |bool|)
		opt norefcounts
		|| f = .FileList[path]
			.FileList.Select(f)
			return true
	
	
	function EditPath2 (|string| s, |bool|)
		opt norefcounts		// using the other seems to cause issues
		if s
			return .editfile(.FileList[s] ?? .FileList.AddExtra(s))


	function EditPath (|string| path, |bool| ChangeFocus=true, |bool|)
		require path.FileExists
