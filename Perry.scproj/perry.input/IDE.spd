		return self


	module
		|int8|						StatsMode
		
		function New (|file| path, |perryide!|)
			rz = PerryIDE(path, false)
			rz.LoadProject
			rz.EditMe.SetFocus
		
	
		function PerryOpenDoc (GUIPasteEvent)
			opt norefcounts
			|| i = (.ide (self) nil)
				require data.fileexists
			  else
				i = perry.ProjContaining(data)
				if !i
					i = perry.IdeAddProj(data)
					if purpose is CreateFile
						i.CanAskingAboutMissing = false
			return i.OpenDoc(data)


	function OpenDoc (|string| Path, |object|)
		require self
		|| p   = path
		|| f   = p.file
		if f.isdir
			p = p.pathdir
		|| ide = self
		if .GotoIncludedFile(p)
			//
		  elseif f.NeedsOwnWindow
			ide = perry.IdeAddProj(p)					// add as project
		  else
			.filelist.addextra(p)						// add root
		startupwindow.hide
		ide.ShowIDE
		return ide

		
	function LoadErrors (|bool| jump, |bool| actual_compile)
		opt norefcounts
		|| txt = .EditMe
		|| doc = txt.document
		|| path = (doc.FilePath (doc) "")
		|| lst = .errorlist
		.filelist.ClearErrors
		
		|error| JumpTo
		|| src = lst.ListSource
		
		|| parse_err = txt.MyError
		if Parse_err is parse
			src <~ parse_err

		|| ActualErrors = 0
		|| sel = txt.Selectedline
		if src.HasAny and src mustbe error
			for err in src
				if err.severity >= ErrorSeverity.Error
					ActualErrors++
				if err.path ~= path
					if txt.AddErrorToLine(err) == sel
						txt.TryShowLineError(sel)
					if jump and (!jumpto or err == lst.FirstSelected)
						jumpto = err
				if actual_compile
					.CommsLogList <~ err.copy
				.filelist.ErrorAt(err)
				
		if jumpto
			txt.JumpToError(jumpto.position)
		  elseif jump and actual_compile
			if .DuringMsgFB
				.DuringMsgFB = false
				lst.select(src.first)
		(self is broken) = ActualErrors > 0
		.RelistStartupErrors
		.CommsLogList.listsource.trim(144)


	function EditRow (|listviewrow| r, |int|)
		description `
-1 means "its OK, its already loaded"
1 means "its OK, we managed to load it"
So anything not 0 means "its OK"`

		if r isa filerow
			rz = .EditFile(r)


	function CurrFileRow (|FileRow|)
		opt norefcounts
		return .FileList.FirstSelected as filerow
	

	function Path (|string|)
		opt norefcounts
		return .editme.FilePath
	

	function EditFile (|FileRow| r, |int|) // loadfile, fileload, fileedit, openfile, fileopen
		require r and r.FilePath and !.DuringLoad
		// the drawing thing needs a document too!
		// why not the same?
		// we could make editfield have an internal draw editor...
		// but at that point we might as well make a general viewer...
		// why not a 3D SDF viewer and audioplayer too.
		// or a fileviewer or a gamepreview player
		// better to have a generalised "fileviewer"
		|| g = (r isa "voi" or "png" or "qoi")
		if .IsGraphics != g
			.IsGraphics = g
			.DuringLoad++
			.ViewAsCurr
			.DuringLoad--
		
		|| ok = (.EditDraw(r) (g) .EditText(r))
		if ok != 1
			return ok

		|| IsNewlyOpened = !r._Document
		|| s = r.DirFile.name
		if s[] == '.'
			s = r.name + "/" + s
		  else
			s = r.name
		.CurrFileName.text = s
		.DuringLoad++
		.filelist.select(r)
		
		if !g
			.LoadErrors(IsNewlyOpened, false)
			if .editme.JeeboxMode isnt expect
				.ProductSep.Collapse
		
		.PopupHide
		.AddToJumpHistory
		if  !g  and  .IsEditingSource
			.Recheck(self)
			.TryReselectASM
		  else
			.HideASM
		.DuringLoad--
		
		return 1
			

	function EditDraw (|FileRow| r, |int|)
		require .drawme.LoadFile(r.FilePath, r)
		.HideASM
		return 1
		

	task CheckScrollErrors (taskgui)
		run
			|| e = .upon.editme
			if e.myerror
				e.TouchScrollBar
			
	
	function EditText (|FileRow| r, |int|) // edittextfile, loadfile, fileload, fileedit, openfile, fileopen
		|textview--| E = .editme
		|document--| doc = r.document
		if e.Document == doc
			return -1
				
		if doc.FilePath.PathIsCode
			doc.JeeboxMode |= documentjeeboxmode.Expect
		
		|| Loaded = E.LoadDocument(doc, true)					#require

//		e.DebugLevel = .DebugLevel(.Debugmode)
		if .debugmode is debug
			.ReloadBreaks

		|| m = .FunctionMenu.SubControl as menu
			m.StopFilter
		doc.CompareTreesOnSave = doc.JeeboxMode is Jeebox
		.ListAllFuncs
		.CheckScrollErrors(0, gui.framestart + 0.25s)		
		|| it = .SharedProjectTabSource
			if !.DuringLoad
				it["edit"] = r.FilePath
			it["pos"] = doc.Position
			perry.save

		return 1


	function HandleAltered
		// well it depends on if we modified shared files?
		for i in perry.OpenProj
			i.ModifiedForCompile = true
		.recheck


	function UpdateActiveFile
		|| d = .editme.Document
			|| l = d.FilePath.Resolve(true)
			if l ~= app.prefs.path
				.UpdatePrefs
			  else
				|| p = .PerryFile
				if l ~= p
					.UpdatePerry(p)
	
	
	function UpdatePerry (|file| ProjConf)
		.startuperrors.clear
		error.BackupErrorSource = @tmp+projconf
		if projconf.exists
			|| conf = projconf.parse
				|| root = .root
				root.RemoveAfter
				.LoadConfSub(conf)
		.LoadStartupErrors
		error.BackupErrorSource = nil
	
	
	function UpdatePrefs
		|| OldPrefs = app._prefs
		app._prefs = nil
		app.prefs()
		if StdErr.ok
			.notify("Reloaded Prefs.")
		  else
			.notify("Prefs are corrupted")
			app._prefs = OldPrefs
		perry.LoadRecents
		¥.LoadFromPrefs


	function ParseErrorDetect
		for e.toplist in .errorlist
			if e isa error
				if e is parse
					e.remove
		
		if .editme.JeeboxMode is Expect
			|| err = .editme.MyError
				ifn err isa error
					log "ParseErrorDetect bug"
				  elseif err is parse
					.errorlist <~ err				// right?

	
	function LoadStartupErrors
		while (|| err = stderr.pop)
			notifications <~ err
			if err.IsBad
				.StartupErrors <~ error(err)


	function SaveDrawing
		.DrawMe.Save


	function SaveEditing (|DocumentAction| Purpose) // savetext, savefile, filesave
		opt norefcounts
		if .DrawMe is visible
			return .SaveDrawing

		.ParseErrorDetect
				
		|| e = .editme
		if purpose is errorchecking
			require e.IsModified
		// otherwise resave anyhow.
		|| Curr = .CurrFileRow

		if (!keys.shift and .ProjectIsCode)
			.filelist.saveall(Purpose, curr)
		  elseif e.IsModified
			require e.Save
		  else
			return
		
		.UpdateActiveFile
		if curr
			curr.lastsize = e.Length
			if curr.FilePath.pathiscode
				.HandleAltered
		(self is modified) = e.ismodified


function string.GetSpeedieProj (|string|)
	rz = self
	while rz and !(rz isa "scproj")
		rz = rz.parent

