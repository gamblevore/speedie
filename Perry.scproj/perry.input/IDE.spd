	destructor
		.Closed


	function Closed (|bool|)
		opt norefcounts
		if !gui.isquitting
			|| p = .prev
			while p
				if p isa perryide
					p.showide
					exit
				p = p.prev
			|| proj = .SharedProjectTabSource
			if perry.HasOthers(proj)
				.RemoveProjFromList
		.clear
		return true

	
	function Perry.HasOthers (|listviewrow| F, |bool|)
		opt norefcounts
		for w.fast in .Projects
			if w != f
				return true
		debugger  // i don't get this? how is this different than checking if we are the last item?
		
		
	function UpdateStatusErrors
		opt norefcounts
		|| str = ""
		|| p = .PerryError
			str = p.name
		.EditStatus.text = str


	function PathExpand (|string| path, |string|)
		if !perry.pathdict
			perry.pathdict = [ "spd"  :  file.speediedir ]
		rz = path.Path_Expand(perry.PathDict)					#expect ("Unrecognised @ in: " + path)
		rz = rz.resolve(true)
	

	function PerryError (|error?|)
		opt norefcounts
		if keys.shift
			|| u = GUI.tooltip.useable
				return u
		|| e = .editme.myerror.useable(0)
			if .editme.ParsedMessage				// don't show simple parse errors
				return e
			if .editme.JeeboxMode is Expect
				return e
		return GUI.tooltip.useable


	function RemoveProjFromList
		opt norefcounts
		|| r = .SharedProjectTabSource
		require r and r.parent

		|| n = r.next
		n ?= r.prev
		.ProjectTabs.selected = n
		.SharedProjectTabSource = message() // for now
		r.remove


	behaviour Tickle
		opt norefcounts
// seems to cause blockages sometimes? why?
//		.Feedback$.Pico.Tickle
	

	behaviour CancelClose
		return !.TryClose(reason)
	
	function TryClose (|GUIActivity| reason, |bool|)
		opt norefcounts
		GUI.SavePrefs							// seems better
		if !.filelist.AskSaveall
			return false						// failed
		|| Q = " before closing the project?"
		if reason is ExitOrTerminate
			Q = " before quitting?"				// todo: this isnt firing...
		if !ClickedCancel(self) or !.MakeNothingRunning(Q)
			return false
		if reason is questioning
			return true
		return .closed
			

	function LocateProjRoot (|string| path, |filerow|)
		opt norefcounts
		|| R = .FindPath(path)$
		|| P = .MainProjFol$
		if r.FilePath[0, p.FilePath]
			return r
			

	function FindPath (|string| path, |filerow|)
		opt norefcounts
		return .FileList.FindAPath(Path) 

		
	function MainProjFol (|filerow|)
		opt norefcounts
		|| it = .FileList
		|| r = it[0]
		|| row = it.FindAPath("./input/", r)
		if !row
			row = it.findapath("./*.input/", r)
		return row


