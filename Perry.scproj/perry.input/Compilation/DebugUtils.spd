	

|| VarPrinter = faststring()	

extend PerryIDE {
function CakeTalk (|SpdProcess| Cake)
	if .DelayedRun.ago > 0.5s
/		.DelayedRun = nil
		.DebugMode &= ~compilemode.paused
		.SetAppInfo		
	
	|| msg = cake.Get$ // getmsg

	|listviewrow--| c = .LogCake
		.LogOneThing(msg, "", C)
		
	if msg == "run"
		.DelayedRun = date.now
	  else
		.DelayedRun = nil
		if msg == "stack" or "break"
			.UpdateStack(msg)
		  elseif msg == "hoi :3"
			.GotHello(msg.name) 
		  else
			Notifications <~ ("unrecognised message", msg)


function GotHello (|string| msg)
	opt norefcounts
	|| m = .DebugMode
	if m is ReceivedHello
		Notifications <~ msg // weird?
	  else
		(M is ReceivedHello)
		.DebugMode = M
		.StrongView(.ViewDebugger) // view debugger!
	.SetAppInfo
	.AppInfo.setfocus // i generally don't like stealing the focus... leads to mistypes
					  // but as long as it runs instantly, it should be OK?


function AppInfoExtra (|unixprocess| r, |string|)
	if !r
		return "Inactive"
	|| st = r.Status
	if st == 0
		return "Exit OK"
	if (r isa SpdProcess) and st.IsRunning
		if .DebugMode is Finished
			return "Killed" // right?
		if .DebugMode isnt ReceivedHello
			return "Waiting..."
		return ""
	if st.IsRunning
		return "Running"
	return st.Name


function SetAppInfo
	|| s = .Project.name.TrimExt
	|| r = .RunCompiledApp

	|| CanDebug = (r isa SpdProcess) and (r.Status.IsRunning) and (.debugmode isnt finished)
	|| Paused = .DebugMode is paused

	for btn in .DebugBtns
		|| Last = btn.IsLast
			btn.text = ("\02\02", "\0E")(paused)
		(btn is enabled) = CanDebug and (Paused or Last)

	if !CanDebug
		.editme._ActiveLine = nil

	|| extra = .AppInfoExtra(r)
		s += "\n("
		s += extra
		s += ")"
	  elseif r
		s += (": " + r.pid)
	.appinfo.text = s
	

function listviewrow.DebugMatch (|listviewrow| New, |int| Ch,  |bool|)
	opt norefcounts
	return New[Ch].ShallowEquals(self[Ch])


function listviewrow.DebugUpdate (|listviewrow| N, |bool|)
	opt norefcounts
	for i in 3
		require .DebugMatch(N,i)

	|| O3 = self[3]
	|| N3 = N[3]
	if O3 and N3
		O3.name = N3.name // update value
		return true

ignore
	+'Main(1)' "/usr/local/speedie/Examples/hello_world.spd" 146
		fs "/usr/local/speedie/Examples/hello_world.spd" 89 "FastString" "\"Start:\\n\""


function listview.DebugFixup (|listviewrow| NewList)
//	.ListSource.DebugFixup(newlist)
	.ListSource = NewList
	.listsource.name = "vars"


// figure out the rest later. we need to deal with inserted/removed items
// or maybe not? the position wont match up???

function listviewrow.DebugFixup (|listviewrow| NewList)
	opt norefcounts
/	|| O = .first
	|| N = NewList.first
	while O and N
		if !O.DebugUpdate(N)
			O.ReplaceWith(N)
		|| argO = O.Last
		|| argN = N.Last
		if argO == @arg and argn == @arg
			
		O++
		N++
	
	// we also want to try to keep older items... so replacing messages with the updated content...
	// but do that later.


function ImproveVar (|listviewrow| s)
	opt norefcounts
	|| thg = s[4]
	|| bad = (thg == @thg and "bad")
		Notifications <~ "Something wrong with var: " + s.name
	(s is error) = bad
	
	|| fs = VarPrinter
	// merge with PerryCopyVar?
	|| ColWidth = 12
	|| Spaces = ColWidth - (s.name.LengthUTF8 + 2)
	fs <~ s.name
	fs <~ ' '
	fs <~ (' ', spaces)
	fs <~ "|"
	fs <~ s[2].name
	fs <~ "|"
	fs <~ " = "
	fs <~ s[3].name
	s.name = fs

	|| Fields = s.Last
	if fields == @arg
		for prop.fast in Fields
			.ImproveVar(prop)
//		A "/usr/local/speedie/Examples/hello_world.spd" 199 "int" "1"
//		_fsf0 "/usr/local/speedie/Examples/hello_world.spd" 211 "FastString" "\"\""


function message.PerryAppendMsg (|int| Item, |string| s)
	opt norefcounts
	VarPrinter <~ s
	|| ch = self[item]
		VarPrinter <~ ch.name


function listviewrow.PerryCopyVar (|string|)
	opt norefcounts
	.PerryAppendMsg(2, "|")
	.PerryAppendMsg(4, "| ")
	.PerryAppendMsg(3, " = ")
	return VarPrinter
}


function @perry.VariableFinder (listview.columnfinder)
	opt norefcounts
	|| upon = self
	if Column
		if column == -2
			return .PerryCopyVar
		if column != -1
			upon = self[3]
	if value == nil
		return upon.name
	if upon
		upon.name = value		


extend perryide {	
function ShowDebugVars (|message| v)
	opt norefcounts
	.Variables.DebugFixup(v)
	for s in v
		.ImproveVar(s)
//	v.Remove // make owner easier to deal with // or not?
	

function UpdateStack (|message| stack)
	opt norefcounts
	
//	|| info = stack.first // nice info about RAM/Pico :]
	|| arg = stack.last$

	.stack.listsource = arg
	
	for m in Arg
		|| l = m.Last
		if l == @arg // assume its a var-dump
			.ShowDebugVars(l)
			exit

	|| Break = stack == "break"
		|| F = arg.first
		if !.stack.FirstSelected
			.stack.Select(F)
		.ClickedStack(F, true) // jump to new place
	  else
		.EditMe._ActiveLine = nil

	|| M = .DebugMode
	if m is Paused != Break
		(M is paused) = Break
		.DebugMode = M
		.SetAppInfo
}

