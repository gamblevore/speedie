

extend PerryIDE {
function CakeTalk (|SpdProcess| Cake)
	|| msg = cake.Get$

/	|| c = .LogCake
		.LogOneThing(msg, "", C)
		
	if msg == "hoi :3"
		.GotHello(msg.name)
	  else
		Notifications <~ ("unrecognised message", msg)
		

function AppInfoExtra (|unixprocess| r, |string|)
	if !r
		return "Inactive"
	|| st = r.Status
	if r isa SpdProcess
		if .DebugMode isnt ReceivedHello
			return "Waiting..."
		if st.IsRunning
			return ""
	return st.Name


function SetAppInfo
	|| s = .Project.name.TrimExt
	|| r = .RunCompiledApp
	|| extra = .AppInfoExtra(r)
		s += "\n("
		s += extra
		s += ")"
	.appinfo.text = s
	

function GotHello (|string| msg)
	|| m = .DebugMode
	if m is ReceivedHello
		Notifications <~ msg // weird?
	  else
		(M is ReceivedHello)
		.DebugMode = m
		.StrongView(.ViewDebugger) // view debugger!
	.SetAppInfo


/// now what?
/// just see that we got anything?
		

		
}

