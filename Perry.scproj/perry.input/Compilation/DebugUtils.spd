
function message.ago (|Duration|)
	if self
		return date.now - .Date

function message.date (assigns:|date|)
	.Position = ((value - gui.OpenedTime) >> 10)
	
function message.date (|date|)
	return (.Position << 10) + gui.OpenedTime
	
	
extend PerryIDE {
function CakeTalk (|SpdProcess| Cake)
	if .DelayedRun.ago > 0.5s
/		.DelayedRun = nil
		.DebugMode &= ~compilemode.paused
		.SetAppInfo		
	
	|| msg = cake.Get$ // getmsg

	|listviewrow--| c = .LogCake
		.LogOneThing(msg, "", C)
		
	if msg == "hoi :3"
		.GotHello(msg.name)
	  elseif msg == "stack" or "break"
		.DelayedRun = nil
		.UpdateStack(msg)
	  elseif msg == "run"
		.DelayedRun = msg
		msg.date = date.now
	  else
		Notifications <~ ("unrecognised message", msg)


function GotHello (|string| msg)
	opt norefcounts
	|| m = .DebugMode
	if m is ReceivedHello
		Notifications <~ msg // weird?
	  else
		(M is ReceivedHello)
		.DebugMode = m
		.StrongView(.ViewDebugger) // view debugger!
	.SetAppInfo


function AppInfoExtra (|unixprocess| r, |string|)
	if !r
		return "Inactive"
	|| st = r.Status
	if st == 0
		return "Exit OK"
	if r isa SpdProcess
		if .DebugMode isnt ReceivedHello
			return "Waiting..."
		if st.IsRunning
			return ""
	return st.Name


function SetAppInfo
	|| s = .Project.name.TrimExt
	|| r = .RunCompiledApp

//	if .DebugMode is Finished
	|| CanDebug = (r isa SpdProcess) and r.Status.IsRunning
	|| Paused = .DebugMode is paused

	for btn in .DebugBtns
		|| Last = btn.IsLast
			btn.text = ("\02\02", "\0E")(paused)
		(btn is enabled) = CanDebug and (Paused or Last)

	|| extra = .AppInfoExtra(r)
		s += "\n("
		s += extra
		s += ")"
	  elseif r
		s += (": " + r.pid)
	.appinfo.text = s
	

function listview.Fixup (|message| NewList)
	.ListSource = NewList
	// we also want to try to keep older items... so replacing messages with the updated content...
	// but do that later.


function UpdateStack (|message| stack)
	opt norefcounts
	
	|| info = stack.first // nice info about RAM/Pico :]
	|| arg = stack.last$

	.stack.Fixup(arg)
	
	for m in Arg
		|| l = m.Last
		if l == @arg // assume its a var-dump
			.Variables.Fixup(l)
			l.Remove // make M easier to deal with
			exit

	|| Break = stack == "break"
		|| F = arg.first
		if !.stack.FirstSelected
			.stack.Select(F)
		ClickedStack(.stack, F) // jump to new place

	|| M = .DebugMode
	if m is Paused != Break
		(M is paused) = Break
		.DebugMode = M
		.SetAppInfo

}

