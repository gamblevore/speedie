

extend PerryIDE
	behaviour KeyDown
		if keys.cmd and .cmdkey(key)
			return true
		if (key is tab) and .OpenedMenu == .autocomplete
			return .autocomplete.doreturn
		if super.keydown(key)
			return true
		if .OpenedMenu or key.IsModifier
			return false
		require !keys.cmd
		
		ifn .focus isa textview // the main listview IS considered editable!
			.Editme.SetFocus	// should I just do this anyhow?
			return .editme.__KeyDown__(key)


	function RunKey (|bool|)
		opt norefcounts
		|| B = .RunButton
		if keys.shift or keys.Option
			return PressingDebug(B)
		if .RunningProd  and  .DebugMode is CakeMode // Run key
			return .ViewRun
		ClickedDebug(B)
		return true


	function CanSwapToAppInfo (|bool|)
		return (.editme.HasFocus or .stack.HasFocus) and (.debugmode is Debug and CakeMode) and .IsViewing(.debugger)		


	function CmdKey (|keys| key, |bool|)
		|| NumKey = key.Number
			return .NumberKey(numkey)
		
		if keys.Option
			return false
		
		if key is t
			return PressingDebug(.runbutton)
		
		if key.IsAccept
			return .ContinueProgram(0)
		
		if key is f
			if .MassSearchField.hasfocus
				|| p = .PrevView
					p.Click
				return .editme.OpenSearch
			return .ShowFind
		
		if key is k
			return .ClearIDE(key)
		
		if key is i
			FileViewerCountCode(.filelist, nil, .filelist.LastSelected.ascell)
			return true
		
		if key is COMMA
			return ClickedPrevNext(.goprev)
		
		if key is ESCAPE
			return .CancelKey

		target osx
			if key.IsCtrl and .CanSwapToAppInfo
				.AppInfo.SetFocus
				return true			
				
		if key is period
			if keys.shift
				return .CancelKey
			return ClickedPrevNext(.gonext)
		
		if key is b
			Clickedcompile(.buildbutton)
			return true
		
		if key is r
			return .RunKey
		
		if key is o
			if keys.shift
				clickedopenfile(self)
			  else
				clickedopenproj(self)
			return true
		
		if key is n
			if keys.shift
				clickedCreatefile(self)
			  else
				clickedCreateproj(self)
			return true

		if key is l							// l = file list
			if keys.option or keys.Shift
				RightClickNext(.goprev)
				return .goprev.searchmenu
			  else
				return .ShowQuickStuff(true)
		
		if key is d
			return .ShowQuickStuff(false)
		
		if  key is s  and  .editme is visible
			.SaveEditing(documentaction.saving)
			return true

		if key is NUM3 or E					// e for error
			return .SaveAndShowErrors
		
		if key is p
			.CommandsMenu.Click
			return true
		
		if key is BACKSLASH
			.editme.AddBreak(.editme.SelRange.x)
		
	
	function OptionCmdNum (|int| Num, |bool|)
		|| w = perry.projects[num-1]
			.ProjectTabs.Selected() = w
		return true
		
		
	function NumberKey (|int| Num, |bool|)
		require !keys.shift
		if keys.Option
			return .OptionCmdNum(num)
		if Num == 9
			.flip(.ProductOut)
			return true
		if Num == 8
			.flip(.SpeedieText)
			return true
		if Num == 7
			return .FlipJeeboxField			
		if Num == 6
			.ASMButton.Click
			return true
		if Num == 5
			return .StrongView(.ViewLog)
		if Num == 4
			return .StrongView(.ViewDebugger)
		if Num == 3
			return .SaveAndShowErrors
		if Num == 2
			return .StrongView(.ViewSearch)
		if Num == 1
			return .StrongView(.ViewFiles)
		if Num == 0
			.ViewTextModeSwap
			return true		



function PressedSearchKeys (GUIKeyEvent)
	opt norefcounts
	|| w = .ide
	
	if key.isaccept
		if self == w.MassReplaceField
			return w.DoReplacements
		return w.MassSearch
		
	|| t = w.MassSearchField
	if (key is down) and (t.selrange == t.text.length)
		w.FoundList.setfocus
		return true
	
	if key.IsCancel
		if t.text
			t.text = ""
		  else
			w.view(W.viewfiles)
		return true



function PressedEditKeys (GUIKeyEvent)
	opt norefcounts
	if self isa TextView
		require .JeeboxMode is Jeebox or Expect
		if key is Decl
			return .PerryDeclKey
		
		require key == -9 or -10 or 27
		|| tabkind = .PerryInsertSyntax(key.abs, key)
			if tabkind == 1
				.ide.EditMeTabRetryThing = 0
			return true

