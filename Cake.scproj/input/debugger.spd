

module debugger
	|message|			PackInfo
	|Message|			Globs
	|[FileWithData]|	FileList
	|Dictionary of filewithdata| FileMap
	|string|			CodeToSrcStr
	|string|			SrcToCodeStr
	|string|			InbuiltBreaks
	|&cakestack?|		StackTrap
	|uint|				DbgLength
	|uint|				OverFlowTrack
	|bool|				WantDebug
	|bool|				BreakMapBad
	|byte|				UserBreakLevel		// The break level that the user set by pressing pause/run/step/etc
	|faststring|		VariablePrinter
	|SavedBreaks|		RealBreaks
	
	
	function CodeToSrc (|uint| Index, |SourceLocation|)
		|| Base = .CodeToSrc
		if index < .dbgLength
			return base[index]
	
	function CodeToSrc (|&SourceLocation|)
		return .CodeToSrcStr.Addr|&SourceLocation|
	
	function SrcToCode (|&SourceMap|)
		return .SrcToCodeStr.Addr|&SourceMap|

	
	function PicoReader (PicoActionFn)	
		self|&cakevm|.Pause		// cool. now we can safely do stuff

	
	function RestoreBreaks
		.StackTrap = nil
		.RealBreaks.Restore
	
	
	function SetAllBreaks (|spdfunc| fn = nil)
		|| B = cake.ActiveBreaks				#require
		|| After = B + .DbgLength
		if fn
			B += fn.Position
			After = B + fn.RangeLength
		while B < After
			B[] |= 1<<31
			B++
	

	
	function ActivateInbuiltBreaks
		|| L = .DbgLength
		|| DX = .RealBreaks.Init(L)				#require
		|| CakeBreak = cake.ActiveBreaks		#require
		|| P = .InbuiltBreaks.Addr|&uint|
		|int| n = .InbuiltBreaks.Length >> 2
		|| C = 0
		for i in n
			|| Code = P[i]
			if Code < L
				CakeBreak[Code] |= (1<<31)
				DX[c++] = Code
		.RealBreaks.Count = C
	
	
	function DebugList (|string| name, |&uint| CakeBreak, |uint| Max)
		target true {
		".......$name......"
		for Raw in .SrcToCode
			|| Src = raw.Loc
			|| FilePos = src.Position
			|| ff = src.file
			|| F = (ff.FileName (ff) "")
			|| PosInCode = Raw.code(Max)
			|| Excl = ""
			|| Op = 0
			if PosInCode < max
				if (Cakebreak[posincode]>>31)
					Excl = "!!"
				Op = (Cakebreak-256K)[posincode] >> 24
				
			"$F $FilePos: $PosInCode$Excl ($op)"
		}
		

	function SourceMap.NeedsChange (|&uint| CakeBreak, |uint| Max, |uint| Active, |bool|)
		|| Code = self|uint|
		if Code < Max
			|| Curr = (CakeBreak[Code] >> 31) << 31
			if Curr != Active
				return true


	function spdfunc.ASMRange (|ivec3|)
		opt norefcounts
		|| f = self[2]
			|| input = xtype.shared
			input.Reset(f.name)
			for i in 3
				rz[i] = Input.hint
				
	
	
	function GoRunClearBreaks (|message| M, |spdfunc| fn, |bool| StepOver, |stepaction|)
		opt norefcounts
		cake.vm.SetBreakLevel(cakevm.kBreakStated)
		
		|| F = debugger.file(m)
		if F == nil
			return StepAction.GoRun
		
		|| CurrFunc = fn.ASMRange
		|| p = m[1].int
		|| a = p + m[2].int
		|| CakeBreak = cake.ActiveBreaks!
		|| N = debugger.dbgLength
		|| Locations = .CodeToSrc
		|| Lowest = int.max
		|| Highest = 0
		
		for i in n
			|| loc = Locations[i]
				|| Src = loc.map(i)
				|| WithinLine = Src.Score(F, P, A, N)
					Lowest = Lowest min i
					Highest = Highest max i
				if WithinLine or (StepOver and (loc out CurrFunc))
					.SetUserBreak(CakeBreak, Src, 0, N)

		while Lowest <= Highest
			|| loc = Locations[lowest]
				if loc out CurrFunc
					|| Src = loc.map(lowest)
					.SetUserBreak(CakeBreak, Src, 0, N)
			Lowest++
		
		return StepAction.GoRun
		
		
	function SetBreaks (|message| M, |bool| Active, |stepaction| Action, |stepaction|)
		opt norefcounts
		|| F = debugger.file(m)
		if f == nil
			return action
		
		|| p = m[1].int
		|| a = p + m[2].int
		debugger.UserMultiBreak(F, p, a, Active<<31)
		cake.perry!.SendBreaks(F)
	
		return action
		
		
	function UserMultiBreak (|FileWithData| Path, |uint| Position, |uint| After, |uint| Active)
		opt norefcounts
		|| CakeBreak = cake.ActiveBreaks$
		|| Max = debugger.dbgLength

		|| BestScore = 0
		|| BestValue = 0
		|| BestCount = 0
		
		target debug
			.DebugList("Start", cakebreak, debugger.dbgLength)
		
		for Src in .SrcToCode
			if src.NeedsChange(cakebreak, Max, active)
				|| Score = Src.Score(path, position, after, Max)
				if Score > BestScore
					BestScore = Score
					BestValue = Src
					BestCount = 1
				  elseif BestScore and (Score == BestScore)
					BestCount++
		
		require BestCount
		if BestCount == 1										// same thing as below, but faster...
			.SetUserBreak(CakeBreak, BestValue, active, max)
		  else
			for Src in .SrcToCode
				|| Score = Src.Score(path, position, after, max)
				if src.NeedsChange(cakebreak, Max, active) and (Score == BestScore)
					.SetUserBreak(CakeBreak, Src, active, max)			

		target debug
			.DebugList("After", cakebreak, debugger.dbgLength)
	
	
	function SetUserBreak (|&uint| CakeBreak, |uint| Code, |uint| Active, |uint| Max)
		if Code < Max
			|| B = (CakeBreak[Code] <<1) >>1
			|| ToAdd = (Active>>31)<<31
			CakeBreak[Code] = B|||ToAdd
			if Active & 1
				if ToAdd
					debugger.RealBreaks.add(code)
				  else
					debugger.RealBreaks.remove(code)
			return
			
		if !.BreakMapBad
			.BreakMapBad = true
			printerror "BreakMap out of range"
	

	function Path (|int| i, |filewithdata|)
		opt norefcounts
		|| f = .FileList[i]
		if f != nil				// what if i == 0? is that an output error? What about lib-internal code? like init-code?
			return f
		expect ("MissingFile " + i)


	function StartUp (|&uint|)
		opt norefcounts
		cake.vm.__View__ = __Dumper__
		|| Dbg = cakevm.kbreaknever+debugger.WantDebug
		|| p = cake.Perry
			cake.vm.__View__ = __PerryView__
			cake.vm.Action(p.pico) = PicoReader	
			dbg = cakevm.kBreakStated
		rz = cake.VM.SetBreakLevel(dbg)
			
		
	function __Dumper__ (cakevm.CakeChef)
		// just dumps everything. Useful for testing the system even works.
		opt norefcounts
		if ErrorCode
			return .PrintCrashTrace(Stack)
		if debugger.VariablePrinter
			|| index = .Index(Stack.code)
			if index|uint| >= debugger.dbgLength
				app.quit "Code pointer escaped: " + index
			.DumpStackAtIndex(Stack)
		

	function cakevm.DumpStackAtIndex (|CakeStack| Stack)
		opt norefcounts
		|| index = .Index(Stack.Code)
		|| Where = debugger.CodeToSrc(index)
		|| fn = spdtable.Find(index)
		|| Path = debugger.path(Where.FileNum)
			|| TabTo = .PrintCodeLocation(Path, fn, Where.Position)
			if fn and fn.HasVar(index)
				.PrintStackVars(index, fn, Stack, TabTo)


	function spdfunc.HasVar (|int| Index, |bool|)
		opt norefcounts
		for v in .obj|&nil||[xvar]|
			if v contains index
				return true
	
	
	function LoadDebugger (|bool|)
		opt norefcounts
		if .PackInfo
			.VariablePrinter = FastString(64)
			require .VariablePrinter
			return .LoadSub(.PackInfo)
		return !(debugger.WantDebug or cake.perry)			#expect "Program file doesn't contain debug info."


	function LoadLibAndGlobs (|message| PackInfo)
		opt norefcounts
		|| LibInfo = cakerun.LibDebug.parse
		xtype.LoadTypes(PackInfo["type"])
		
		.Globs = PackInfo.giveitem("glob", @msg)
		|| LibGlobs = LibInfo["glob"]						// probably need to keep the libglobs.
			.globs.Appendall(libglobs)						// merge!
	
	
	function LoadSub (|message| PackInfo, |bool|)
		opt norefcounts

		.LoadLibAndGlobs(packinfo)
		
		.LoadFiles(PackInfo["files"].value.decompress)
		.SrcToCodeStr = PackInfo["breakmap"]
		.InbuiltBreaks = PackInfo["breakpoint"]
		.CodeToSrcStr = PackInfo["pos"]
		.dbgLength = .CodeToSrcStr.Length >> 2

		|| L2 = SpdTable.CodeLength
		expect (L2 == .dbgLength)				("Map-length is: " + .dbgLength) + (" but code-length is: " + L2)
		expect (L2 < 1MB)						("Oversized source-map: " + L2)
		
		.ActivateInbuiltBreaks
		
		for fn in SpdTable.funcs
			fn.LoadVars
		
		return StdErr.ok
	
	
	function PrintBreaks
		target debug {

		|| T = SpdTable.CodeLength
		|filewithdata--| LastFile
		printline "--- BreakInfo ---"
		
		for raw in .SrcToCode
			|| Src = raw.Loc
			|| P = src.Position
			|| Code = raw.code(T)
			|| fn = src.FileNum
				|filewithdata--| File = debugger.path(fn)
				if File!=LastFile
					printline
					printline File
					LastFile = file
			  else
				print "(NoFile) "
			printline "textpos: $P,  code: $code"
		
		printline "--- InbuiltBreaks ---"
		|| CakeBreak = cake.ActiveBreaks$
		for i in T
			|| Code = CakeBreak[i]
				printline "break: $i"
	}
	
	
	helper LoadFiles (|string| List)
		opt norefcounts
		|| Last = 0
		|| i = 0
		|| out = .FileList
		.FileMap = Dictionary()
		while
			|| P = list.NextField('\n', Last)
			if P == nil
				exit
			|| F = FileWithData(P, i++)
			out <~ F
			.FileMap![F] = F

		
		
function CakeVM.PrintCodeLocation (|FileWithData| File,  |spdfunc| fn,  |uint| Position, |int|)
	print "\t\t\t\t\t\t"
	if TerminalColor.RainbowTerm
		print terminalcolor.green.render
	
	print file.filename
	print " "
	if fn
		print fn.name
		print ": "
	
	if TerminalColor.RainbowTerm
		print TerminalColor.normal

	|| Code = File.GetLine(position)
	|| comment = Code.find("//")								// whoop!
		Code = Code[0, comment]
	Code = Code.trim

	printline Code
	return 7 + file.filename.Length + fn.Name.Length


function CakeVM.PrintStackVars (|int| Index, |spdfunc| Fn, |CakeStack| Stack, |int| TabTo)
	opt norefcounts
	index -= fn.Position
	for v in fn.obj|[xvar]|
		if v contains index
			print "\t\t\t\t\t\t"
			v.Print(Stack, TabTo)
	printline

