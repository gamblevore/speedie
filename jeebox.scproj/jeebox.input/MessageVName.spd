
/*
	Jeebox internals. By Theodore H. Smith...
*/


// Simplified to one vfunc on message. Can merge with listview.ColumFinder... later!

extend message
	virtual TableCell (|int| Column=0, assigns:|string?| Value = nil, |string|)
		opt norefcounts
		real self
		if column >= 0
			self = self[Column]$
		if value == nil // get
			return .name
		.name = value // set


	function SearchColumns (|string| find, |int| n, |int|)
		opt norefcounts
		for i in n
			|| s = .__TableCell__(i)
			if find ~= s
				rz = 2
				exit
			rz = (s contains find)|int|

