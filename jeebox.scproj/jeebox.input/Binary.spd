function Parser.fBinary (ParseHandler)
	|| End = .data.find(")#", start+2)
		|| S = parser.range(Start+2, End)
		.nextstart = End + 2
		return parser(nil, @bin, start, .splitter.id(s.unhex, @bin))
	return .ErrorAdd( "Binary section didn't close!", start )

