 

	
function dictionary.DocumentCached (|string| path, |document|)
	opt norefcounts
	|| i = .valuelower(path) as cachedpath
		return i.value


class CachedPath
	linkage
		cpp_part CaP
	|string|				Path
	|document--?|			Value
	|dictionary--|			Cache

	constructor (|string| p, |dictionary| c, |document| v)
		c.valuelower(p) = self
		.path = p
		.cache = c
		.value = v


	function DeRef
		require self
		.cache.valuelower(.path) = nil
		.path = ""



libinternal document.RemoveViewer (|guicontrol| g)
	opt norefcounts
	if .viewers.find(g)
		g.remove


libinternal document.AddViewer (|guicontrol| g)
	opt norefcounts
	if !.viewers.find(g)
		.viewers <~ g
	if g isa textview
		g.UpdateToDocument(self, documentaction.InitialSet)

