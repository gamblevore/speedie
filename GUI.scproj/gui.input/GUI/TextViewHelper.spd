

datatype TextLineFlags (uint16)
	flags
		BothBreaks = [BreakPoint, RealBreakPoint]
		Reached
		Colored
		Found
		CurrFound
		Last
		StartsNormally
		AvoidLastChar
		FakeMsg
		Selected


class TextViewLine (list)
	linkage
		cpp_part Line
	contains TextViewLine

	|string|				Text
	|message?|				Message
	|Error?|				LineError
	|float|					UserInfo
	|int|					AdderPos
	|int|					vline
	|int|					tline
	|TextLineFlags|			TextState

	constructor (|int| p = 0)
		.position = p
	
	render
		if !.parent
			for c in self
				c.render(fs)
				fs <~ '\n'
		  else
			fs <~ "${.position}: "
			fs.AppendQuotedEscape(.text)


	libinternal ClearForPrepare
		.message = nil
		.TextState = nil
		.lineerror = nil
		.text = ""


	function textview.FindBackwardsIgnoringSpaces (|string| name, |int| pos, |codepoint|)
		while --pos >= 0
			|| t = .text[pos]
			if t != ' ' and '\t'
				if rz
					return t
				pos -= name.length - 1
				require .Text[pos, name]
				rz = '\n'
		

	operator contains (|ind| b, |bool|)
		|| d = .range
		d.x2 -= (self is last)
		return d contains b


	inline SyntaxIs (|TextLineFlags| F, |bool|)
		return .TextState&F

	function syntaxis (|TextLineFlags| F, assigns:|bool|)
		|| T = .textstate&~F
		T |= F*value
		.textstate = T


	libinternal XOfChar (|ind| Pos, |int|)
		return .SquaresAtByte(pos) * font.width

	
	libinternal SquaresAtByte (|ind| B, |int|)
		opt norefcounts
		b -= .position
		require b > 0
		
		|| StrEnd = b + .text.addr
		for (c.CodePoints in .text) (Start)
			if Start >= Strend
				exit
			if c == '\t'
				rz += rz.tabswidth
			  else
				rz++

	
	function After (|int|)
		return .position + .text.length


	libinternal ByteOfX (|int| X, |ind|)
		|| chars	= (x max 0) / font.width
		|| bytes	= .text.CountBytesInSquares(chars) min .text.length
		return bytes + .position
	

	libinternal message.AddPos (|int| p)
		opt norefcounts
		for ch.flat in self
			ch.position += p


	libinternal ColoriseText (|message| msg, |bool| ParsedOK, |message|)
		.adderpos = -1
		.message = nil
		isnt fakemsg

		if msg
			return .ColoriseSub(msg)

		require !parsedok

		|| r = .text.Parse
			.adderpos = .position // not sure what its used for?
			r.addpos(.position)
			.ColoriseSub(r)
			is fakemsg
		  else
			stderr.pop
	
	
	libinternal Range (|intrange|)
		|| p = .position
		|| L = .text.length
		return (P, P+L)

	
	libinternal EmptyLine (|bool|)
		return (.text == 1) and .text[].istextline


	libinternal ColoriseSub (|message| srch, |message|)
		opt norefcounts
		rz = .ColoriseSub2(srch)
		|| r = rz
		|| range = .range
		if !r or r.StartsAfter(range)
			r = srch
			while r
				r = r.parent
				if (r == @arg) and r.StartsNotAfter(range)
					rz ?= r
					if !r.endsbefore(range)
						exit
		
		if r and !r.StartsAfter(range)
			(self is BothBreaks) = r is breakpoint
			.adderpos = .position // isn't it r.position?
			.message = r
		  else
			isnt breakpoint
	
		
	libinternal ColoriseSub2 (|message| srch, |message|)
		opt norefcounts
		|| r	= .range
		while srch.EndsBefore(r)
			|| p = srch
			srch = srch.flatnext
			if !srch
				require p.IsContainer
				return p
		// OK now... this thing at least, doesn't end before us

		
		if srch.StartsAfter(r)					// starting after is OK, so lets just use it now!
			return srch
		
		// What to do with things that wrap us, but we have something better?
//		if r[0] <= srch.Position and r[1] >= srch.After
//			return srch							// seems good?
		
		|| Attempt = Srch
		while Attempt.StartsNotAfter(R) and Attempt.iscontainer
			|| nxt = Attempt.flatnext			#loop
			if nxt.StartsAfter(r)
				exit
			Attempt = nxt
			if !attempt.endsbefore(r)
				srch = Attempt
		
		return srch


	libinternal message.NextColor (|int| s, |message|)
		opt norefcounts
		|| nxt = self
		rz = nxt
		|| LastAfter = nxt.after
		while nxt
			|| curr = nxt
			nxt	= nxt.flatnext
			if curr.after <= s					// too far back
				if curr.after > lastafter
					LastAfter = curr.after
					rz = curr
				continue						// go next

			|| cp	= curr.position
			if (cp <= s)
				rz = curr
			  elseif !nxt or nxt.position > cp
				exit

			|| par	= curr.parent				// special coloring
			if par and par.contains(s, true)
				|| pt = par.func
				if pt == @type
					return par
				if !curr.prev
					if (pt == @decl) or (pt == @func and curr == @thg) 
						return par


	libinternal Ends (|bool|)
		return .endswithline or self is last
		
		
	libinternal EndsWithLine (|bool|)
		return .text.last.IsTextLine


	libinternal DrawSelSub (|image| where,  |ivec2| R,  |textview| parent,  |int| vline,  |drawstyle| g)
		opt min 3
		|| M = .Range
		require (r.x <= m.x2) and (r.x2 >= m.x)
		|| Start  = .SquaresAtByte(R.x1 max M.x1)
		|| Finish = .SquaresAtByte(R.x2 min M.x2)
		require Finish > Start
		
		|| Y = parent.lasttop - (vline+1) * parent.lineheight
		|| X = parent.TextLeft
		|| n = font.Width
		x += n - 2

		|| sel = (x+start*N,  y,  x+finish*N,  y+parent.lineheight)
		sel.x -= (Start == 0)
		sel.x--
		
		|| LinePos = r.x2-(1+m.x1)
		if (.text[linepos].IsTextline) or (r.x2 > m.x2)
			sel.x2 = parent.lastright-1
		  elseif r.x2==m.x2
			sel.x2++

		if parent.SingleLine
			sel.y--
		Where.DrawRectStyled(sel, g)

	
	libinternal ColorLineNum (GUITextLineBreakColor)
		opt norefcounts
		|| msg = .Message
		if !msg or msg == @arg
			return colors.white(0.175)
		return colors.white(0.35)
	
	
	libinternal SetLineNum (|int| t, |int|)
		.tline = t
		return t + .endswithline

	
	libinternal TrySetError (|error| e, |bool|)
		opt norefcounts
		|| old = .LineError
			e.when = old.when
		.LineError = e
		e.Obj = self
		return e != old


	libinternal InitDefaults (|textview| parent, |int| t, |int|)
		opt norefcounts
		|| e = parent.MyError
			if (self contains e.position) and (!e.obj) 
				e.obj = self
				.LineError = e
		if parent.ParsedMessage
			is colored
		return .SetLineNum(t)


	libinternal TakeEntireText (|string| txt, |ind| p, |ind|)
		.Text = txt[p, int.max]
		(self is AvoidLastChar) = .EndsWithLine
		is last
	
	
	libinternal FindWhereLineBreaks (|string| txt, |int| MaxWidth, |bool| IsInline, |ind| p, |ind|)
		(self is StartsNormally) = txt[p-1].IsTextLine
		.position = p
		if .vline > 1000K
			return .TakeEntireText(txt, p)					// just give up wrapping

		if p >= txt.length // edge case.
			.Text = ""
			is last
			return -1

		|| i = txt.WrapSub(MaxWidth, IsInline, p)
		.Text = txt[p, i]
		(self is AvoidLastChar) = .EndsWithLine
		if (i >= txt.length) and !.EndsWithLine
			is last
			return -1
		isnt last
		return i


libinternal textview.DrawErrorMark (|image| where, |textviewline| s, |vec4| C)
	|| v = s.vline|float|
	|float| N = .WrappedLines.last!.vline|float|
	|| Y = 1.0 - (v/n)
	require y >= 0 and y <= 1.0
	
	Y *= .height|float|
	|| p = ivec2(.lastright - 5, .lastrect.y + Y|int|)
	|| strength = .DrawScrollStrength * c.a * 0.35
	for i in -1 to 1
		C.a = Strength
		C.a += Strength * !i
		|| range = (p.x+4) downto (p.x-4)
		for xx in Range
			|| px = where[xx,p.y+i]
			px.overlay(C.premul)
			C.a -= 0.04



libinternal textview.DrawErrorBackground (|image| Where, |int| y, |TextViewLine| D)
	opt norefcounts
	|| e = d.LineError$
	if (e is parse) and .ParsedMessage			// obviously it parsed ok.
		d.LineError = nil
		return
	|| r = .lastrect
	y++
	r.y	= y
	r.y2 = y + .lineheight
	|| lm= 0.225
	|| v = e.Textcolor(lm)
	if e == .myerror
		v.a *= 0.75

	if d contains .sel1
		.myerror = e
	if e is parse
		|| Alpa = (e.when.guiago.float - 1.0) * lm
		if (Alpa <= lm)
			GUI.touch(Self)
		v.a = alpa min lm
	where.DrawRect(r, v.px)



libinternal textview.DrawBackGround (|image| Where, |int| y, |imagepixel| col)
	|| r	= .lastrect
	r.y		= y + 1
	r.y2	= y + .lineheight + 1
	where.DrawRect(r, col)


libinternal textview.DrawLighter (|image| Where, |int| y)
	|| col = (1.0, 1.0, 1.0, 0.06)
	.drawbackground(Where, y, col.px)


libinternal TextView.DrawLineNumber (|image| Where,  |TextViewLine| D,  |int| y,  |int|)
	opt norefcounts
	
	|| x = .DrawOneStartLine(d.text) 
	|int| big = ._LineNumWidth
		x += big * font.width
		|| P = (x-(4+font.width), y)
		|| TLine = d.tline
		|| pr = d.prev
		|| lc = .LineNumColor(d)
		if !pr or (tline != pr.tline)
			|| F = font.small!
			while
				|| c = TLine mod 10
				TLine = (tline - c)/10
				c += '0'
				F.DrawChar(c, Where, p, lc)
				p.x -= font.Width
				loop tline

	|| A = .Alignment
	if  A is right  and  A isnt left
		|| m = d.text.Bounds.x * font.width+8
		|| w = .width
		x += w - m
	return x


libinternal TextView.UseColorAnyway (|int|)
	if !.isinline
		if .ParsedMessage // or .myerror
			return 2
		return 3


libinternal TextView.SpaceDisplayAsDot (|TextViewLine| d, |int|)
	require .UsingLineNumbers
	rz = 0x13FFFFFF
	if ._DrawInLineArea & 1
		._DrawInLineArea |= 2
		|| mx = .MouseXY.x
		if mx < .LineNumRight and mx >= .LastLeft
			rz += 0x2F000000
			if d is Selected
				rz += 0x3F000000
		  elseif d is Selected
			rz += 0x0F000000

	

libinternal TextView.DrawOneLine (|image| Where, |TextViewLine| D, |int| y, |int| UseCol)
	opt norefcounts
	opt min 3
	(d isnt Selected)
	|| GoUp = (7 - .lineheight)/2
	if d.LineError
		if .MyError
			.DrawErrorBackground(where, y+GoUp, d)
		  else
			d.LineError = nil							// sigh. crappy bug fix
	
	|| m = ._ActiveLine
		if d contains m.Position
			|| f = .FilePath
			if m ~= f
				|| bg = ¥.ActiveTextLine
				.Drawbackground(where, y + GoUp, bg)

	if .CanDrawSelected(d)									// linelight
		(d is Selected)
		.DrawLighter(where, y+GoUp)
	
	|| x	 = .DrawLineNumber(where, d, y)-1
	|| state = MsgTextDrawState(x, d)
	|| NoDrawFirst =  (self is CodeEditor)  and  (d is breakpoint or RealBreakPoint)
		|| col = vec4(0)
		if (._ActiveLine) and (d is realbreakpoint)!=(d is BreakPoint)
			col = (1.0, 1.0, 0.75, 0.375)
			if d is realbreakpoint
				col = colors.blue(0.375)
		state.font.DrawChar('\18', Where, (x, y), col, 0)
		
	
	|codepoint| Prev
	|| xlimit = .lastrect.x2
	|| SpaceDisplay = .SpaceDisplayAsDot(d)
	for (c.CodePoints2 in state.t) (pos)
		x = state.next(c, pos)
		if x > xlimit
			exit
		ifn useCol & 2
			UseCol = (d is colored)|int|
		|| col = ¥.GetColor(state.msg, usecol, pos)
		if d.LineError  and  c == 9  and  prev == 32
			c = -c
		if NoDrawFirst and c == '/'
			NoDrawFirst = false
		  else
			|| yadd = 0
			if (c == 32) and SpaceDisplay
				yadd = 3
				c = '.'
				col = SpaceDisplay
			state.font.DrawChar(c, Where, (x, y+yadd), col, 1)
		prev = c
	
	if .AutoLim(d)
		if (._CanAutoComplete != 2) or (!.text)
			if d.IsLast				// last line draw too early with autocomplete
				x += font.width		// but we shouldn't need this!
			.DrawAuto(Where, x, y)


libinternal TextView.AutoLim (|textviewline| d, |bool|)
	if (._CanAutoComplete >= 1) and ._AutoCompleteString
		|| after = d.after
		if d is last
			after++ // ??
		if (.Sel1 == after-1)  and  (d.Ends)
			return true


function TextView.AutoCompleteShowingDots_ (|int|)
	|| n = ._autocompleteback
	if ._AutoCompleteString=="" or ._AutoCompleteString == n
		return -1
	return n


libinternal TextView.DrawAuto (|image| where, |int| x, |int| y)
	|| n = .AutoCompleteShowingDots_
	|| str = (._autocompletestring[n, int.max] (n>=0) "...")
	where.drawtext(str, (x,y), colors.white(0.3))
	


struct MsgTextDrawState
	linkage: cpp_Part msc
	|int|					i
	|int|					x
	|int|					Adder
	|message--?|			msg
	|string--|				t
	|image--|				font
	
	libinternal Next (|$codepoint| Char, |$int| ppos, |int|)
		opt norefcounts
		|| c = Char
		|| w = 1
		if (c == '\t')
			w = .i.tabsWidth
		rz   = .x
		.x   = rz + w*font.width
		.i  += w
		|| m = .msg
			|| pos	= ppos
			Char	= c.ImproveDraw(.t, pos)
			pos		+= .adder, ppos = pos
			.msg	= m.NextColor(pos)
			
		
	module
		libinternal New (|int| x, |textviewline| d, |MsgTextDrawState|)
			rz.i = 0
			rz.x = x
			rz.adder = d.AdderPos
			rz.msg = d.message
			rz.t = d.text
			rz.font = font.small!


libinternal int.LineNumWidth (|int|)
	opt norefcounts
	rz = 2
	while self >= 100
		self /= 10
		rz++


function string.TextLineCount (|int|)
	|| a = 0
	|| b = 0
	for c in self
		a += c == 10 // faster
		b += c == 13
	return a + b


libinternal string.CountBytesInSquares (|int| Remain, |int|)
	|| n = .length
	require remain > 0 and n > 0
	|| i = 0

	for (c.codepoints in self) (After)
		if i >= remain
			return (after - .addr)|int|
		if c == '\t'
			i += i.tabswidth
		  else
			i++

	return .length


libinternal TextView.DrawOneStartLine (|string| txt, |int|)
	|| s = .lastrect
	|| x = s.x1 + font.width
	if .Alignment is Horizontal
		|| W = (txt.length) * font.width
		x += (s.width - W)/2
	return x



extend message
	libinternal EndsBefore (|intrange| r, |bool|)
		return .after <= r.x
	libinternal StartsAfter (|intrange| r, |bool|)
		return .position >= r.x2
	libinternal StartsNotAfter (|intrange| r, |bool|)
		return .position <= r.x
		
	
	
libinternal Textviewline.ReclaimStart (|int| p, |textviewline|)
	description "Sigh. Just an idea to 'reclaim' existing textviewlines. Will take probably 3 days work to get this reliable. Don't wanna do this right now! Just a placeholder right now. Actual code not here." 
	opt norefcounts
	rz = self
	while
		if rz.after > p
			return rz 
		rz = rz.next #loop


libinternal Textviewline.ReclaimEnd (|int| T, |int| dp, |textviewline|)
	opt norefcounts
	|| v  = .vline
	
	while
		self = .next #loop
		.position += dp
		T = .setlinenum(T)
		.vline = ++v
	return self


function message.FlatRange (|intrange|)
	opt norefcounts
	rz = (int.max, 0)
	for ch.flat in self
		|| ss = ch.range
		if ss.x >= 0
			rz.x = rz.x min ss.x
			rz.x2 = rz.x2 max ss.x2


function error.TextColor (|float| alpha=1.0, |vec4|)
	rz = .Severity.Color(alpha)
	if .Severity <= ErrorSeverity.Problem
		rz *= (0.6, 0.6, 0.6, 1.0)
	if .Severity <= ErrorSeverity.Hint
		rz.a *= 0.5


libinternal textview.LineNumColor (|textviewline| D, |imagepixel|)
	opt norefcounts
	|| fn = .OnDrawLineNumber ?? textviewline.ColorLineNum
	|| w = (fn)(d, nil, (._DrawInLineArea&1)!=0)
	if d is Selected
		w.a *= 2.0
	|| c = w.a.mix(.gnormal.bg.Color, w)
	c.a = 1.0
	return c.px


libinternal textview.CanDrawSelected (|TextViewLine| D, |bool|)
	require (self is editable) and !.SingleLine
	// should involve ._PreferPrevLine or something calling it.
	// or else we can select "off the end" of a line, by clicking after it
	// yet we draw the next line "light"
	|| sr = .SelRange	
	if !sr.width and (d.range contains sr.x)
		return true
	if (sr.x >= d.range.x2) and !d.next
		return true

