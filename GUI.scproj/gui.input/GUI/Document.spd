

class Document (list)
	linkage
		cpp_part Doc
	contains DocumentReverser
	|int|					ScrollPos
	|uint16|				MaxUndos
	|bool|					WasJbin				// Merge into jeeboxmode?
	|bool|					WasCompressed		// Also?
	|DocumentJeeboxMode|	JeeboxMode
	|bool|					CompareTreesOnSave
	|byte|					_AvoidMerge
	|bool|					_LoadedFromFile
	|string|				Text
	|DocumentReverser?|		Current
	|DocumentReverser?|		Original
	|message?|				DocParsed
	|string|				FilePath
	|date|					FileDate
	|date|					ViewDate
	|intrange|				TypingPlace
	|[GuiControl]|			Viewers // we should have an array that does NOT own the items
	|CachedPath|			Ref		// because the control already always owns the document.
	
	
	constructor (|string| path, |int| Undos)
		.maxundos	= Undos
		.FilePath	= path
		.ref		= CachedPath(path, document.Cache_, self)
//		.Viewers	= DocumentViewer(nil)
//		.JeeboxMode = DocumentJeeboxMode.Prefer // Actually no. then todo/txt files get linenumbers
												// Its a known file-type, so it should be set explicitly.
		if path isa "spd" or "box" or "xml" or "jb"
			.jeeboxmode = DocumentJeeboxMode.Expect

	
	destructor
		.Viewers.clear
		.ref.DeRef
	
	
	render
		opt norefcounts
		fs <~ .FilePath
		fs <~ "\n"
		super.render(fs)
	

	libinternal ClearDoc
		.original = nil
		.current = nil
		._loadedfromfile = false
		.clear
	
	
	setter DocParsed (|message?|)
		.DocParsed = value
		.JeeboxMode = .jeeboxmode.SyntaxIs(documentjeeboxmode.jeebox, value!=nil)
		
	
	function MoveTo (|string| path)
		require .FilePath != path
		.ref.Cache.ValueLower(.FilePath) = nil
		.FilePath = path
		.ref.Path = path
		.ref.Cache.ValueLower(path) = .ref
	

	libinternal TryMerge (|string| Insertion, |ivec2| Point, |string| OldText, |bool|)
		opt norefcounts
		|| av = ._AvoidMerge
			._AvoidMerge = av - 1
			return false
		|| c = .Current
			return c.TryMerge(Insertion, point, oldtext)
	

	libinternal AddState (|string| Insertion, |ivec2| Point, |string| OldText)
		opt norefcounts
		|| Merged = .TryMerge(Insertion, Point, OldText)
		|| c = .current
			c.RemoveAfter
		  else
			.clear
		
		require !merged
		|| latest = DocumentReverser(Insertion, Point, OldText)
		self <~ latest
		.current = latest
		.Trim


	inline IsModified (|bool|)
		return .current != .Original


	function SaveBeforeClose (|bool|)
		if !.IsModified
			return true
		|| Q = "Save file ".append(.FilePath.name, "?") // compiler should do this automatically?
		// or does sometimes... on:   "Save file " + .FilePath.name + "?"
		// whatever... fix that later. Or perhaps its just from faststring? 
		|| Answer = Q.AskSaveOrCancel()
		if answer >= 1		// save
			return .save(DocumentAction.Closing)
		return answer == 0	// don't


	libinternal SaveText (|string|)
		|| t = .text
		if .Wasjbin
			t = t.digest
		if .WasCompressed
			t = t.compress
		return t


	function Save (|int| Purpose=0, |ind|)
		(Purpose)
		// purpose is unused, right now. It was used, originally... and might be again.
		|| l = .FilePath			#require
		|| c = .current				#require	
		|| f = l.file
		|| t = .SaveText
		|| KeepDate = false
		rz = t.Length
		|| Deleted = !t and !f.visible
			if !f.delete
				rz = -1
		  else
			KeepDate = .FindKeepDate(t, f)
			if !f.WriteAll(t)
				rz = -1
		f.close
		if rz
			.original = c
			|date| NewDate
			if !deleted
				if KeepDate
					NewDate = .filedate
				  else
					NewDate = gui.FrameStart	// just clear the subsecond bits
				f.modified = NewDate
			.filedate = f.modified				// read it back to be sure its what we think it is.
			.UpdateSavedState
			

	libinternal FindKeepDate (|string| t,  |file| f,  |bool|)
		require .CompareTreesOnSave
		|| old = f.ReadAll
			|| jold = old.Parse
				|| tp = t.parse
					rz = jold.deepequals(tp)
			  else
				stderr.pop

	
	libinternal SimpleUpdateFromDisk (|bool|)
		|| d = .FileDate
		if !d
			return true				// unsaved... must be ok.
		
		|| DiskMod = .FilePath.file.modified
		|| DiskIsNewer = DiskMod - d
		if DiskIsNewer == 0
			return true				// no need
		if .IsModified
			return false			// not sure which to use.
		return .Load(true)			// Reload!

	
	function CheckModified (|bool|)
		if .SimpleUpdateFromDisk
			return true
		
		|| Options	= ["Save", "Reload"]
		|| Answer	= confirmationdialog.ask("The file ${.FilePath.name} has been externally modified. Reload or resave?", "", Options)
		if answer >= 1				// save
			.save(DocumentAction.Saving)
		if answer == 0				// reload
			.Load(true)
		return true

	
	libinternal GetViewer (|int| i, |TextView|)
		opt norefcounts
		|| v = .Viewers[i]
			if !v.Window
				.Viewers.Remove(i)
				return nil
			if v isa TextView
				return v
	
	
	iterator viewer
		|| i = .viewers.length
		while --i >= 0
			yield .GetViewer(i)
		
	
	function ShowErrorInViewers
		opt norefcounts
		for v.Viewer in self
			if v
				v.parse


	libinternal UpdateViewers (|DocumentAction| Reason)
		opt norefcounts
		.notifychange
		for v.Viewer in self
			if v
				v.UpdateToDocument(self, Reason)


	libinternal UpdateSavedState 
		opt norefcounts
		for v.Viewer in self
			if v
				(v is modified) = false
				(v.ontextchanged)(v, documentaction.Saving, false)?
	
	
	function InvalidJeebox (|bool|)
		|| j = .JeeboxMode
		return (j isnt Jeebox) & (j is Expect)

	
	libinternal LoadSub (|bool| ChangedExternal, |bool|)
		|| f = .FilePath.file
		|| Lim = document.AskLimit(f)
		|| Data	= f.readall(lim)						#require
		
		.viewdate = gui.FrameStart
		.wascompressed = data.IsCompressed
		if .WasCompressed
			data = data.decompress

		|| bin = data.Isjbin
		.WasJBin = bin									// remove and use the mode instead?
		if bin
			.JeeboxMode |= documentjeeboxmode.Expect
			.DocParsed = data.parse
			if .DocParsed
				data = .DocParsed.render
			
		.filedate = f.modified
		if ChangedExternal
			._AvoidMerge = 2
			.TypingPlace = ivec2(.scrollpos)
			|string--| OldText = .Text
			.addstate(data, (0, oldtext.length), OldText)
			.Original = .Current
		  else
			.clearDoc
			.TypingPlace = nil

		.text = data
		._LoadedFromFile = true
		return true


	libinternal Load (|bool| ChangedExternal, |bool|)
		if ChangedExternal or !._LoadedFromFile
			require .LoadSub(ChangedExternal)
			.UpdateViewers(DocumentAction.Initialset)
		return true


	libinternal Trim
		opt norefcounts
		|| L = .last$
		|| n = .maxundos-1
		while --n > 0
			l--
			require l

		l.RemoveBefore
		|| o = .Original
		if o and !o.parent
			.Original = nil


	libinternal NotifyChange
		opt norefcounts
		for v.Viewer in self
			if v
				v.TextAlteredForDraw |= 4

	
	module
		|dictionary of cachedpath| Cache_ = dictionary()
		
		function New (|string| path, |document|)
			cpp_part NewShared
			if path
				rz = .Cache_.DocumentCached(path)
			rz ?= document(path, 1000)
		
		libinternal AskLimit (|file| f, |int|)
			|| n = f.size
			if n <= 128MB or n >= int.max
				return 128MB
			if "The file ${f.name} is ${n|int|.StrSize} big. Do you still want to load it?\n\nText-editor performance may suffer.".confirm
				return n+1
			return 128MB



datatype DocumentJeeboxMode (byte)
	flags
		NotJeebox = 0
		Prefer
		Expect
		Colorise = Expect+Prefer
		Jeebox
	
	syntax is (|DocumentJeeboxMode| m, |bool|)
		inlined
		return self&m
	
	syntax is (|DocumentJeeboxMode| m, assigns:|bool|, |DocumentJeeboxMode|)
		inlined
		self &=~m
		self |= m*value
		return self



extend TextView
	libinternal KeepUndosOnLoseFocus (|bool|)
		return (self is editable) and !.isinline


	libinternal TryCaptureUndo (|string| NewText, |ivec2| NewSel,  |string| Insertion, |ivec2| Point, |string| OldText)
		opt NoRefCounts
		|| u = .undoer
		if !u
			super.textset(NewText)
			is modified
			.touch
			.TypingPlaceTry(NewSel, true, nil)
			(.OnTextChanged)(self, documentaction.Typing, true)?
			return

		u.AddState(Insertion, Point, OldText)
		u.text = NewText
		u.TypingPlace = NewSel
		u.UpdateViewers(documentaction.Typing)


	function DontMergeUndo
		opt norefcounts
		|| u = ._Viewing
			u._AvoidMerge = 2


//	libinternal ExpectCurr (||)
//		opt NoRefCounts
//		|| c = .Current
//		if (!c)
//			c = .first
//			.current = c
//		return c


	function Undo (|bool| undo)
		opt norefcounts
		|| u = ._viewing$
		// I think we should have a default first state?
		// at least... it makes the undo simpler.
		// We need some way to say that we are at the start, or at the end
		// If .current being nil... is the default state... what do we do?
		|| m = u.current
		
		if undo
			expect (m) (Beep)
			m.Undo(u)
			m = m.prev
		  else
			if m
				m = m.next	
			  else
				m = u.first
			expect (m) (beep)
			
			m.Redo(u)

		u._AvoidMerge = 1
		u.current = m
		u.NotifyChange
		.UpdateToDocument(u, documentaction.UndoOrRedo)
		

	libinternal UpdateModState (|document| D, |int| reason)
		|| ismod = d.ismodified
		if (self is modified) != ismod
			(self is modified) = ismod
			if ismod
				.touch
		(.OnTextChanged)(self, Reason, ismod)?


	libinternal UpdateToDocument (|document| D, |DocumentAction| Reason)
		require .parent
		if d.text
			self|guicontrol|.text = d.text
			if reason isnt Initialset
				|| ty = d.typingplace
				.TypingPlaceTry(ty, true, nil)
				if reason is typing
					.ShowTypingPlace(ty)
				  elseif reason is UndoOrRedo
					.show(ty.x)
		  else	
			.Clear(d.text)		
		
		.UpdateModState(d, reason)	



class DocumentReverser (list)
	linkage
		cpp_part Undo
	contains DocumentReverser
	
	|string|			Inserted
	|ivec2|				Point
	
	constructor (|string| Insertion, |ivec2| Point, |string| OldText)
		.Inserted = Insertion
		.Point = point
		.obj = OldText
	
	
	libinternal Undo (|document| D)
		// abcdef<123>gh		//	"123"	(6,6)	""
		// abcdef123gh
		opt norefcounts

		|| t = .obj as string
		expect (t!=nil)
		|| x = .Point.x
		d.Text = d.Text.insert(t, (x, x+.inserted.length))
		|| TP = x + t.Length
		d.TypingPlace = (tp, tp)
		
		
	libinternal Redo (|document| D)
		|| P = .Point
		d.Text = d.Text.Insert(.inserted, P)
		|| x = p.x + .inserted.length
		d.TypingPlace = (x,x)


	libinternal TryMerge (|string| Insertion, |ivec2| New, |string| Del, |bool|)
		opt norefcounts
		|| MyOld = .obj|&nil||string|
		require MyOld isa string
		|| Mine = .Inserted.Length
		|| Old = .point
		if !Insertion
			if !Mine
				if Old.x == New.x2											// DELETE
					// abcdefghj<k>			// (9, 10), "", "k"
					// abcdefgh<j>			// (8, 9),  "", "j"
					.obj = Del + MyOld
					.point.x = New.x
					return true
				if Old.x == New.x											// FWD DELETE
					// abcde<f>gh			// (5, 6),  "", "f"
					// abcde<g>h			// (5, 6),  "", "g"
					.obj = MyOld + Del
					return true
		  else
			if Mine and !Old.width and !New.width and Old.x+Mine == New.x	// INSERT
				// abcdefgh<c>				// (8, 8),  "c", ""
				// abcdefghc<d>				// (9, 9),  "d", ""
				.Inserted += Insertion
				return true



datatype DocumentAction (byte)
	constants
		InitialSet		= 0
		Typing			= 1
		UndoOrRedo		= 2
		Saving			= 3
		Closing			= 4
		ErrorChecking	= 5
		
	syntax is (|DocumentAction| V, |bool|)
		inlined
		return self==V
		


