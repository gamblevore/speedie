

class Document (list)
	linkage
		cpp_part Doc
	contains DocumentReverser
	|int|					ScrollPos
	|uint16|				MaxUndos
	|bool|					WasJbin				// Merge into jeeboxmode?
	|bool|					WasCompressed		// Also?
	|DocumentJeeboxMode|	JeeboxMode
	|bool|					CompareTreesOnSave

	|byte|					_AvoidMerge
	|bool|					_LoadedFromFile
	|bool|					_DuringUndo
	|byte|					_DuringInsert	
	|string|				Text
	|DocumentReverser?|		Current
	|DocumentReverser?|		Original
	|message?|				DocParsed
	|string|				FilePath
	|date|					FileDate
	|date|					ViewDate
	|intrange|				TypingPlace
	|[GuiControl]|			Viewers // we should have an array that does NOT own the items
	|CachedPath|			Ref		// because the control already always owns the document.
	
	
	constructor (|string| path, |int| Undos)
		.maxundos	= Undos
		.FilePath	= path
		.ref		= CachedPath(path, document.Cache_, self)
//		.Viewers	= DocumentViewer(nil)
//		.JeeboxMode = DocumentJeeboxMode.Prefer // Actually no. then todo/txt files get linenumbers
												// Its a known file-type, so it should be set explicitly.
		if path isa "spd" or "box" or "xml" or "jb"
			.jeeboxmode = DocumentJeeboxMode.Expect

	
	destructor
		.Viewers.clear
		.ref.DeRef
	
	
	render
		opt norefcounts
		fs <~ .FilePath
		fs <~ "\n"
		super.render(fs)
	

	
	libinternal ClearDoc
		.original = nil
		.current = nil
		._loadedfromfile = false
		.clear
	
	
	setter DocParsed (|message?|)
		.DocParsed = value
		.JeeboxMode = .jeeboxmode.SyntaxIs(documentjeeboxmode.jeebox, value!=nil)
		
	
	function MoveTo (|string| path)
		require .FilePath != path
		.ref.Cache.ValueLower(.FilePath) = nil
		.FilePath = path
		.ref.Path = path
		.ref.Cache.ValueLower(path) = .ref
	

	libinternal TryMerge (|string| Insertion, |ivec2| Point, |string| OldText, |bool|)
		opt norefcounts
		|| av = ._AvoidMerge
			._AvoidMerge = av - 1
			return false
		|| c = .Current
			return c.TryMerge(Insertion, point, oldtext)
	

	libinternal AddState (|string| Insertion, |ivec2| Point, |string| LostText)
		opt norefcounts
		|| Merged = .TryMerge(Insertion, Point, LostText)
		|| c = .current
			c.RemoveAfter
		  else
			.clear
		
		if !merged
			|| latest = DocumentReverser(Insertion, Point, LostText)
			self <~ latest
			.current = latest
			.Trim


	inline IsModified (|bool|)
		return .current != .Original


	function SaveBeforeClose (|bool|)
		if !.IsModified
			return true
		|| Q = "Save file ".append(.FilePath.name, "?") // compiler should do this automatically?
		// or does sometimes... on:   "Save file " + .FilePath.name + "?"
		// whatever... fix that later. Or perhaps its just from faststring? 
		|| Answer = Q.AskSaveOrCancel()
		if answer >= 1		// save
			return .save(DocumentAction.Closing)
		return answer == 0	// don't


	libinternal SaveText (|string|)
		|| t = .text
		if .Wasjbin
			t = t.digest
		if .WasCompressed
			t = t.compress
		return t


	function Save (|int| Purpose=0, |ind|)
		(Purpose)
		// purpose is unused, right now. It was used, originally... and might be again.
		|| l = .FilePath			#require
		|| f = l.file
		|| t = .SaveText
		|| KeepDate = false
		rz = t.Length
		|| Deleted = !t and !f.visible
			if !f.delete
				rz = -1
		  else
			KeepDate = .FindKeepDate(t, f)
			if !f.WriteAll(t)
				rz = -1
		f.close
		if rz
			|| c = .current
				.original = c
			|date| NewDate
			if !deleted
				if KeepDate
					NewDate = .filedate
				  else
					NewDate = gui.FrameStart	// just clear the subsecond bits
				f.modified = NewDate
			.filedate = f.modified				// read it back to be sure its what we think it is.
			.UpdateSavedState
			

	libinternal FindKeepDate (|string| t,  |file| f,  |bool|)
		require .CompareTreesOnSave
		|| old = f.ReadAll
			|| jold = old.Parse
				|| tp = t.parse
					rz = jold.deepequals(tp)
			  else
				stderr.pop

	
	libinternal SimpleUpdateFromDisk (|bool|)
		|| d = .FileDate
		if !d
			return true				// unsaved... must be ok.
		
		|| DiskMod = .FilePath.file.modified
		|| DiskIsNewer = DiskMod - d
		if DiskIsNewer == 0
			return true				// no need
		if .IsModified
			return false			// not sure which to use.
		return .Load(true)			// Reload!

	
	function CheckModified (|bool|)
		if .SimpleUpdateFromDisk
			return true
		
		|| Options	= ["Save", "Reload"]
		|| Answer	= confirmationdialog.ask("The file ${.FilePath.name} has been externally modified. Reload or resave?", "", Options)
		if answer >= 1				// save
			.save(DocumentAction.Saving)
		if answer == 0				// reload
			.Load(true)
		return true

	
	libinternal GetViewer (|int| i, |TextView|)
		opt norefcounts
		|| v = .Viewers[i]
			if !v.Window
				.Viewers.Remove(i)
				return nil
			if v isa TextView
				return v
	
	
	iterator viewer
		|| i = .viewers.length
		while --i >= 0
			yield .GetViewer(i)
		
	
	function ShowErrorInViewers
		opt norefcounts
		for v.Viewer in self
			if v
				v.parse


	libinternal UpdateSavedState 
		opt norefcounts
		for v.Viewer in self
			if v
				(v is modified) = false
				(v.ontextchanged)(v, documentaction.Saving, false)?
	
	
	function InvalidJeebox (|bool|)
		|| j = .JeeboxMode
		return (j isnt Jeebox) & (j is Expect)

	
	libinternal LoadSub (|bool| ChangedExternal, |bool|)
		|| f = .FilePath.file
		|| Lim = document.AskLimit(f)
		|| Data	= f.readall(lim)						#require
		
		.viewdate = gui.FrameStart
		.wascompressed = data.IsCompressed
		if .WasCompressed
			data = data.decompress

		|| bin = data.Isjbin
		.WasJBin = bin									// remove and use the mode instead?
		if bin
			.JeeboxMode |= documentjeeboxmode.Expect
			.DocParsed = data.parse
			if .DocParsed
				data = .DocParsed.render
			
		.filedate = f.modified
		if ChangedExternal
			._AvoidMerge = 2
			.TypingPlace = ivec2(.scrollpos)
			|string--| OldText = .Text
			.addstate(data, (0, oldtext.length), OldText)
			.Original = .Current
		  else
			.clearDoc
			.TypingPlace = nil

		.text = data
		._LoadedFromFile = true
		return true


	libinternal Load (|bool| ChangedExternal, |bool|)
		if ChangedExternal or !._LoadedFromFile
			require .LoadSub(ChangedExternal)

			for v.Viewer in self
				if v
					v.UpdateToDocument(self, DocumentAction.Initialset)
		return true


	libinternal Trim
		opt norefcounts
		|| L = .last$
		|| n = .maxundos-1
		while --n > 0
			l--
			require l

		l.RemoveBefore
		|| o = .Original
		if o and !o.parent
			.Original = nil


	module
		|{cachedpath}| Cache_ = dictionary()
		
		function New (|string| path, |document|)
			cpp_part NewShared
			if path
				rz = .Cache_.DocumentCached(path)
			rz ?= document(path, 1000)
		
		libinternal AskLimit (|file| f, |int|)
			|| n = f.size
			if n <= 128MB or n >= int.max
				return 128MB
			if "The file ${f.name} is ${n|int|.StrSize} big. Do you still want to load it?\n\nText-editor performance may suffer.".confirm
				return n+1
			return 128MB



datatype DocumentJeeboxMode (byte)
	flags
		NotJeebox = 0
		Prefer
		Expect
		Colorise = Expect+Prefer
		Jeebox
	
	syntax is (|DocumentJeeboxMode| m, |bool|)
		inlined
		return self&m
	
	syntax is (|DocumentJeeboxMode| m, assigns:|bool|, |DocumentJeeboxMode|)
		inlined
		self &=~m
		self |= m*value
		return self



extend TextView
	libinternal SimpleInsert (|string| NewText, |ivec2| NewSel)
		super.textset(NewText)
		is modified
		.touch
		.TrySelect(NewSel, true, nil)
		(.OnTextChanged)(self, documentaction.TextInserted, true)?


	libinternal InsertionCapture (|string| GainedText, |ivec4| Point, |string| NewText, |ivec2| NewSel)
		opt NoRefCounts
		|| u = .undoer
		if !u
			return .SimpleInsert(newtext, newsel)

		require !u._DuringInsert						// no recurse!
		u._DuringInsert = 1
		u.TypingPlace = NewSel

		if !u._DuringUndo
			|| LostText = .text[Point.xy]
			u.AddState(GainedText, Point.xy, LostText)

		// Point = point.TextMapShrink(u.text, NewText)	// for copy/paste larger blocks that barely altered anything
		// disable for now.
		for v.viewer in u
			if v
				v|guicontrol|.text = NewText
				v.PrepareLinesOfText(Point)
		
		u.text = NewText

		for v.viewer in u
			if v
				v.UpdateToDocument(u, documentaction.TextInserted)
		u._DuringInsert = 0


	autogen DontMergeUndo
		opt norefcounts
		|| u = ._Viewing
			u._AvoidMerge = 2
		
		
	inline Undo (|bool| Undo)
		opt norefcounts
		|| u = ._viewing
			.undo(undo, u)
	
	
	autogen guicontrol.Undo (|bool| Undo, |document| u)
		opt norefcounts
		expect (!u._Duringundo) (beep) // event madness

		|| m = u.current
		|| Next = m.prev
		
		if undo
			expect (m) (beep)
		  else
			next = u.first
			if m
				next = m.next
			expect (next) (beep)
		
		
		u._AvoidMerge = 1
		u._DuringUndo = true
		u.current = Next

		// could be extended to work in general
		// but I want to get this working, first!
		if self isa textview
			if undo
				.Undo_(u, m!)
			  else
				|| P = next!.point
				.inserttext(next!.inserted, P)
			
		u._DuringUndo = false
	

	
	libinternal Undo_ (|document| D, |documentreverser| m)
		// abcdef<123>gh		//	"123"	(6,6)	""
		// abcdef123gh
		|| t = m.obj as string
		if t != nil
			|| x = m.Point.x
			|| P = (x, x + m.inserted.length)
			.InsertText(t, p)
		  else
/			d.cleardoc // huh?
									
	
	
	libinternal UpdateToDocument (|document| D, |DocumentAction| Reason)
		opt norefcounts
		|| text = d.text
		self|guicontrol|.text = text // does nothing if already done

		if !text
			.Clear(text)		
		  elseif reason isnt Initialset
			|| ty = d.typingplace
			.TrySelect(ty, true, nil)
			if reason is TextInserted
				.ShowSelection(ty)
		
		|| ismod = d.ismodified
		if (self is modified) != ismod
			(self is modified) = ismod
			if ismod
				.touch
		(.OnTextChanged)(self, Reason, ismod)?



class DocumentReverser (list)
	linkage
		cpp_part Undo
	contains DocumentReverser
	
	|string|			Inserted
	|ivec2|				Point
	
	constructor (|string| Insertion, |ivec2| Point, |string| OldText)
		.Inserted = Insertion
		.Point = point
		.obj = OldText


	libinternal TryMerge (|string| Insertion, |ivec2| New, |string| Del, |bool|)
		opt norefcounts
		|| MyOld = .obj|&nil||string|
		require MyOld isa string
		|| Mine = .Inserted.Length
		|| Old = .point
		if !Insertion
			if !Mine
				if Old.x == New.x2											// DELETE
					// abcdefghj<k>			// (9, 10), "", "k"
					// abcdefgh<j>			// (8, 9),  "", "j"
					.obj = Del + MyOld
					.point.x = New.x
					return true
				if Old.x == New.x											// FWD DELETE
					// abcde<f>gh			// (5, 6),  "", "f"
					// abcde<g>h			// (5, 6),  "", "g"
					.obj = MyOld + Del
					return true
		  else
			if Mine and !Old.width and !New.width and Old.x+Mine == New.x	// INSERT
				// abcdefgh<c>				// (8, 8),  "c", ""
				// abcdefghc<d>				// (9, 9),  "d", ""
				.Inserted += Insertion
				return true



datatype DocumentAction (byte)
	constants
		InitialSet		= 0
		TextInserted	= 1
		Saving			= 3
		Closing			= 4
		ErrorChecking	= 5
		
	syntax is (|DocumentAction| V, |bool|)
		inlined
		return self==V
		

