#!/usr/local/bin/spd

main (|FileSizeInt| Amount) {
	|| name = amount.strsize
	|| xml = "auto_generated_$name.xml".out							#require
	using xml.file.name
	xml <~ `<?xml version="1.0" encoding="utf-8"?>
<Catalog>
`
	|| Caps = ('A', 'Z')
	|| Low  = ('a', 'z')
    while xml < Amount
		|| alive = ("yes", "no")(0.5[])

	    xml <~ "
	<Book>
	    <Title>${caps.text(16)}</Title>
	    <Author alive=\"${alive}\">${low.text(8)} ${low.text(2)}</Author>
	</Book>"
	
	xml <~ `
</Catalog>`

	xml.Flush
}


function ivec2.text (|int| n, |string|)
	return random.shared.Text(n, .x, .y)
