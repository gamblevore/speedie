

main
	for exp in 2 to 5: for num in 2 to 100000 {
		if num.IsArmStrong(exp)
			"	$num is armstrong($exp)"
	}


function int.IsArmStrong (|int| exp = 3, |bool|)
	for d in .digits
		self -= d pow exp
	return self == 0
	

