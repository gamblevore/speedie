
// new task system

function @SCClass.NewTask (CollectFunc)
//	node.Name = "role"
	|| name = node[@thg]
	|| prms = name.Next(@nil)
	require name and prms
	if prms == @bra or @list
		prms.func = @prm
	  else
		prms = @prm.msg
		name.next = prms
	
	|| arg = prms.next(@arg)
	using node
	|| bra = @bra.msg
	name.next = bra
	bra <~ (@thg, "task")
	bra.obj = prms				// hehe
	|| con = "constructor () {
		._Objects = –taskvars
	}".parse
	arg.first = con

	|| conprm = con.first
	|| conarg = conprm.next
	arg.FindTaskRun(conprm, conarg, prms)

	|| task = SCClass.NeuRole(node, name_space, ErrPlace)|scmodule|
		task.cls!.IsRole = 2
	return task
		


function Message.MakeTaskVar (|message| prm, |message| arg, |message|)
	is editable // whatever
	|| name = .VarName

	using self
		arg <~ NewEqRel(@sdot+name, @thg + name)
		prm <~ .copy // :)
	
	
function Message.FindTaskRun (|message| prm, |message| arg, |message| FnPrms)
	opt norefcounts
	|| found = 0
	for ch in self
		if ch == @decl
			ch.MakeTaskVar(prm, arg)
		  elseif ch istmp "run"
			if found
				error (ch, "Duplicate run statements")
			  elseif ch[@arg].ExpectLast
				ch.name = "syntax"
				ch.first = fnprms
				ch.first = @thg + "call"
			found++


target debug2
	task LessThanTest (|int| i, |bool|)
		|string|	a
		|int| 		b
		|string|	c
		run: visible, return i < .b

	function testtest
		visible
		|LessThanTest| xxx


ignore {

// roles can't define properties.
// So... then what?
// we want to turn the decls into functions, right? but which are objects or not?
// we could just scatter them? the thing is... we STILL don't know which are objects
// or ints or floats... they need different treatment. We could DELAY that treatment???

role LessThanTest (task)
	|int| Vs
	syntax call (|int| i, |bool|)
		return i < .Vs
	constructor () {
	
	}
	destructor {
	
	}

function caller (|lessthantest| abc)
	abc.Items[0] = 3
}

