
// new task system

function @SCClass.NewTask (CollectFunc)
//	node.Name = "role"
	|| name = node[@thg]
	|| prms = name.Next(@nil)
	require name and prms
	if prms == @bra or @list
		prms.func = @prm
	  else
		prms = @prm.msg
		name.next = prms
	
	|| arg = prms.next(@arg)
	|| run = arg.FindTaskRun		#require
	
	using node
		|| bra = @bra.msg
		name.next = bra
		bra <~ (@thg, "task")
		bra.obj = prms				// hehe
		|| con = @tmp + "constructor"
		arg.first = con
		con <~ @prm
		con <~ @arg
		|| des = arg.msg(@tmp, "destructor")
		des <~ @arg
		
	using run
		run.name = "syntax"
		run.first = prms
		run.first = @thg + "call"
	
	
	
	|| task = SCClass.NeuRole(node, name_space, ErrPlace)|scmodule|
		task.cls!.IsRole = 2
	return task
		


function Message.FindTaskRun (|message|)
	opt norefcounts
	for ch in self
		if ch == @decl
			(ch is editable) // whatever
		  elseif ch istmp "run"
			if rz
				error (ch, "Duplicate run statements")
			  elseif ch[@arg].ExpectLast
				rz = ch

target debug2
	task LessThanTest (|int| i, |bool|)
		|int| Vs
		run: visible, return i < .Vs

	function testtest
		visible
		|LessThanTest| xxx


ignore {

// roles can't define properties.
// So... then what?
// we want to turn the decls into functions, right? but which are objects or not?
// we could just scatter them? the thing is... we STILL don't know which are objects
// or ints or floats... they need different treatment. We could DELAY that treatment???

role LessThanTest (task)
	|int| Vs
	syntax call (|int| i, |bool|)
		return i < .Vs
	constructor () {
	
	}
	destructor {
	
	}

function caller (|lessthantest| abc)
	abc.Items[0] = 3
}

