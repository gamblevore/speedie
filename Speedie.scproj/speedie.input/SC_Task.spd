

// new task system

module SCTasks {

function CollectAll
	opt norefcounts
	|| T = typetask
	require T
	for ch in compiler.taskstodo
		|| P = ch.obj|scnode|!
		debugat 0
		if P == Compiler.program
			P = T.Modul
		  elseif p isa scclass
			p = p.modul|scclass|
		|| found = newtaskActual(ch, P)
			found.parent = p
			P.tryadd(ch, found, found.name)


function NewTaskActual (|Message| node, |SCNode| name_space, |SCNode?|)
	opt norefcounts
	|| name = node[@thg]
	|| fields = name.Next(@nil)
	require name and fields
	if fields == @bra or @list
		fields.func = @bra
	  else
		fields = @bra.msg
		name.next = fields
	
	|| arg = fields.next(@arg)		#require
	arg.takeallfrom(fields)
	using node
	fields <~ (@sdot, "task")
	|| con = "constructor () {super.constructor(&run, –taskvars)}"~digest
	arg.BuildTask(con!)
	node.name = "role" 

	|| task = SCClass.NeuRole(node, name_space, node)|scmodule|
		task.cls!.IsRole = 2
	return task


function NewTask (CollectFunc)
	node.obj = name_space
	compiler.taskstodo <~ node
	return compiler.program


function Message.MakeTaskVar  (|message!| con, |message|)
	is editable // whatever
	|| prm = con.first!
	|| arg = prm.next!
	|| name = .VarName										#require
	|| type = .first
	expect (type and type!=@emb) (type, "Missing type")

	using self
		arg <~ NewEqRel(@sdot + name, @thg + name)
		prm <~ .copy // :)


function Message.BuildRunTask (|message| con, |message| prms, |int|)
	opt norefcounts
	|| arg = prms.next(@arg)
	require arg.ExpectLast
	|| f = prms.func
	expect (f == @bra or @list) (prms)
	
	.prev = con
	.name = "function"
	f = prms.first.func

	rz = 2
	ifn f == @thg or @dot
		|| brah = @bra.msg
		brah <~ (@thg, "task")
		.first = brah
		rz = 1
	
	.first = @thg + "run"


function Message.BuildTask (|message| con)
	opt norefcounts
	|| prms = con
	|| State = 0
	for ch in self
		if ch == @decl
			ch.MakeTaskVar(con)
		  elseif ch istmp "run"
			expect (!State) (ch, "Duplicate run statements")
			prms = ch[@nil]										#require
			state = ch.BuildRunTask(con, prms)					#require
	
	expect (state) (self, "Missing 'run' statement")
	require state == 1

	.appendmacro(sctasks.argh, [prms])
	|| callprms = .flatlast
	callprms <~ (@thg, "self")
	for p in prms
		|| ty = p.second
			callprms <~ ty.copy

	
|| argh = `
	role task (task)
		prototype prototype (^"_0")
		syntax call (^"_0")
			return (._func|prototype|)()
`.macro

}

