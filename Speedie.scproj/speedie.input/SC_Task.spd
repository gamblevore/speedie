task LessThan (|string| a, |int| b, |string| c)
	run (|int| i, |bool|)
		return i < .b

	module
		function abc (task.lessthan.prototype) 
			|| x = 0
		function def
			|| xxx = LessThan("a", 5, "c")
			|| z = .abc(xxx,0)

