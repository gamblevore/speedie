

// new task system

// 	task LessThan (|string| a, |int| b, |string| c)

function @SCClass.NewTask (CollectFunc)
	|| name = node[@thg]
	|| fields = name.Next(@nil)
	require name and fields
	if fields == @bra or @list
		fields.func = @prm
	  else
		fields = @prm.msg
		name.next = fields
	
	|| arg = fields.next(@arg)		#require
	while (|| ch = fields.last)
		arg.first = ch
	using node
	|| bra = @bra.msg
	name.next = bra
	bra <~ (@thg, "task")
	|| con = "constructor () {super.constructor(&run, –taskvars)}"~digest
	arg.BuildTask(con!)

	|| task = SCClass.NeuRole(node, name_space, ErrPlace)|scmodule|
		task.cls!.IsRole = 2
	return task
		


function Message.MakeTaskVar  (|message!| con, |message|)
	is editable // whatever
	|| prm = con.first!
	|| arg = prm.next!
	|| name = .VarName										#require
	|| type = .first
	expect (type and type!=@emb) (type, "Missing type")

	using self
		arg <~ NewEqRel(@sdot + name, @thg + name)
		prm <~ .copy // :)

	
	
function Message.BuildTask (|message| con)
	opt norefcounts
	|message| prms = con
	|| found = 0
	for ch in self
		if ch == @decl
			ch.MakeTaskVar(con)
		  elseif ch istmp "run"
			if found
				error (ch, "Duplicate run statements")
			  elseif ch[@arg].ExpectLast
				ch.prev = con
				ch.name = "function"
				|| brah = @bra.msg
				brah <~ (@thg, "task_prototype")
				ch.first = brah
				ch.first = @thg + "run"
			found++	
	
	|| Caller = (macros.TaskCaller)(prms, @thg + "task_prototype")
	|| CallPrms = Caller.FlatLast.parent
	for p in prms
		|| ty = p.second
			callprms <~ ty.copy
	
	|| proto = .msg(@tmp, "prototype")
	proto <~ (@thg, "task_prototype")
	proto <~ prms.copy
	
	self <~ Caller



function Compiler.MiniTests
	target debug2
		|| xxx = LessThanTest("a", 5, "c")
		|| yyy = (xxx)(0)


target debug2
	task LessThanTest (|string| a, |int| b, |string| c)
		run (|int| i, |bool|)
			return i < .b

	task LessThanTest (|float| f)
		run (LessThanTest2)
			return i < .b

