


extend Assembler {


function IsASMConst (|message| exp, |bool|)
	|| fn = exp.func
	if fn == @num
		return true
	if fn == @thg // now what?
		return ASMType.ThgSub(self, exp, ASMReg.ConstRequest)


function PrmCollectSpd (|message| prms,  |SCFunction| fn,  |uint64|) // paramcollect, paramscollect
	opt norefcounts
	|int64| sh
	|| args = fn.args
	|| i = 0
	if ! prms.AsFunc
		rz |= 16
	
	for p.fast in prms
		|int64| v = .µFuncPrms(p!, args[i++]!).reg
		sh += 5
		rz |= v << sh
	
	rz |= i


function PrmCollect (|message| prms,  |SCFunction| fn,  |uint64|)
	opt norefcounts
	
	if !fn.HasCVersion
		return .PrmCollectSpd(prms, fn)
	
	|int64| sh = 64
	|| fc = 0
	|| ic = 0
	|| args = fn.args
	|| n = args.Length

	for Ints in 2
		|| i = 0
		for p.fast in prms
			|| ty = p.ASMDecl
			if ty.SpecialReg|int| != Ints
				|int64| v = .µFuncPrms(p!, args[i]!).reg
				sh -= 5
				rz  |=  v << sh
				ic += ints
				fc += !ints
			i++
	
	rz >>= 64-((n*5)+12)
	if fc>8 or ic>8			// hmmm
	rz |= fn.ASMReturn.SpecialReg << 11
	if fc
		rz |= (8-fc) << 6
		rz |= (8-ic) << 0
	  else
		rz |= (17-ic) << 6


function message.RegCheck (|int| Bad)
	if bad
		error (self, "Too many registers in use. No space for result.")


function CallFunc (|message| exp,  |asmreg| dest,  |scfunction| fn,  |asmreg|)
	opt norefcounts
	.ASMReach(fn)
	|uint| v = 0
	
	|| ret = .state.return
	if ret and (dest is ExitAtAll)
		v = ret.reg
		v ?= .state.parentvars|uint|.log2 + 1
		dest = dest.Temp(ret)
	  else
		|| vd = .VDecls
		v = vd.log2					// we can't use .declareme, .log2 is used to protect the vars. 
		if v == 0 or dest.reg != v
			v++
		vd |= 1<<v
		.Vdecls = vd
		dest &=~ asmreg.tempflags
		exp.RegCheck(vd & .vtemps)
	
	exp.RegCheck((v >= 32)|int|)
	dest.reg = v
	
	|| ty = fn.ASMReturn(dest)
	return ty.Simplify


function GrabAddr (|message| exp, |AsmReg| Dest, |scdecl| d, |asmreg| T, |asmreg|)
	opt norefcounts
	dest = .TempTyped(d, dest)
	
	|| fat = exp.GRAB(dest, t)
	fat.CurrGrabID = .CurrFuncGrab
	if false and d.IsInt and !d.IsBool
		|| L = t.BitLoss(D)
			
			// What if it has enough bits already?    How can we tell?
			// So... we never need it if its 64-bit.  Hmmmm
			// What if its 32-bit... I mean... most ops are 32-bit clean, right?
			// We could compare the bit-size of the param-passed, and register?
			// see if its more? rarely, right?

			// need a real problem case before we can write this...
		
			L = L.SetSign(t.signed)
			fat.const = L // what if we are passing a const? well... its not an address!
	return fat * dest.HaveAddr


target false {
function RegClear (|message| exp, |&fatasm| C, |asmreg| R)
	c.CurrGrabID = 0
	|| L = c.Const
	|| signed = L < 0
		L = -L
	.BFLG_Sub(exp, R, R, L, L, signed)
}


function ClearTrampling (|message| AllPrms,  |&fatasm| Start, |&fatasm| Fn)
	// asmtodo: unnecessary? Values are always 32 or 64-bit. everthing else should be
	// set correctly, right? remove later?
	opt norefcounts
	if 0: AllPrms.FNC3, AllPrms.FNCX3			// MARK USED

	|| c = .Last - 1
	while C >= Start
		if (c isa asm.GRAB)
			if c.CurrGrabID == .CurrFuncGrab
//				.RegClear(AllPrms, c, c.output.asmreg)
				.SetRegister(c.regonly(1), nil, fn)
		c--
		
}




function SCFunction.HasCVersion (|bool|)
	if .IsCppInBuilt == 2						// cpp_nothing: For JB_Decr, JB_Ternary, etc
		debugat
		return false

	if .IsLibrary
		return true

	return self is wrapper



function assembler.CantLinkInline (|message| exp, |bool| DepthOK, |asmreg|)				// dofunction function
	if !.InlineDepth
		|| reason = ("Unable to inline function", "Inline depth too great")(.EntireInlineFailed<2)
		error (exp, reason)
	.EntireInlineFailed = 1 + !DepthOK
	return asmreg()



function assembler.DepthOK (|scfunction| fn, |bool|)
	opt inline
	return .InlineDepth < (.InlineDepthLimit + (fn is linkinline)|uint|)


function assembler.ASMTableID (|message| Exp, |scfunction| fn, |int|)
	rz = fn.FPackID + 31
	if rz <= 31							// failed!
		if !Compiler.InPerry					// shut the compiler up
			if !fn.islibrary or !.state.fn.islibrary
				error (exp, "Missing PackID[1]")
		rz = 0xFFFF	

function @ASMType.ASMFunction (fn_asm)				// dofunction function
	opt norefcounts
	|| prms = exp.last!
	|| TableID = 0
	
	.parentsanity
	
	|| fn = prms.AsFunc
		|| intrin = fn.Intrinsic
			return .DoIntrinsic(exp, dest, fn, intrin)
			
		if  fn isnt CantInline  and  fn isnt cpp
			|| DepthOK = .Depthok(fn)
				|| MiniDest = .AskForInline(prms, dest, fn)
					return MiniDest
			if fn is LinkInline
				return .CantLinkInline(exp, depthok)
		
		TableID = .asmtableid(exp, fn)
		
	  else // function pointers
		|| f = exp.first!
		TableID = .µ(f).Reg
		|| dcl = f.ASMDecl
		fn = dcl.Type.FuncProto						#expect (exp)

	dest = .CallFunc(exp, dest, fn)

	|| Start = .curr
	.CurrFuncGrab++
	
	|| Closer = .OpenVars
	|| P = .PrmCollect(prms, fn)
	.CloseVars(Closer)
	
	|| PExt = P >> 32
	(dest isnt Const)								// why would it be?
	|| fat = exp.FNC(dest, TableID, P,  PExt)		// prms.fncx
	if fn.HasCVersion
		if 0: exp.fncx
		fat._op = asm.FNCX
	fat._op += PExt > 0
	fat.µRefCount += fn isnt STATELESS				// NOICE!

	.ClearTrampling(exp, Start, fat)
	.CurrFuncGrab--
	
	if fn is Killer
		dest = asmreg.exit
		fat.µrefcount++
	return fat * dest



function assembler.ASMReach (|SCFunction| fn)
	opt norefcounts
	|| orig = .out
	if Orig.MyReacher and !orig.IsLibrary
		(fn is usedbyasm)
		if fn is Constructor // gotta reach the destructor also
			fn = fn.cls!.DestructorFunc
			if fn
				(fn is usedbyasm)


