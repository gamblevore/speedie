class SCObject
	|array? of SCBase|			LinkFrom
	|string|					Name
	|Message?|					Source
	|byte|						NoAutoComplete
	|Byte|						AllocSource
	|uint| 						LinkedFrom
	

	render
		|| cname = ((.class.name|uint64|)+2)|cstring|
		fs <~ cname
		fs <~ ": "
		fs <~ .name
	
	function SyntaxExpect ( |string| Error )
		cpp_part Fail
//		print "Object Failed Expect: "
//		printline .objectid
//		app.printstacktrace
		errorreceiver.NewError( .source, Error )

//	syntax equals (|string| s, |bool| aware, |bool|)
//		return .name ~= s

	function File (|SCFile?|)
		opt norefcounts
		|| src = .Source
			return src.SCFile
		if self isa SCModule
			return .cls.file?
	
	function AnySource (|message|)
		opt norefcounts
		|| s = .source
			return s
		if self isa scmodule
			|| c = .cls
				return c.sourcearg
