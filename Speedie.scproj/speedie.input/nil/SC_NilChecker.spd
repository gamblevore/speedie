

extend_module ArchonPurger {
	dispatch NilSyxes (NilTrackerFn)
		@thg:	Thing
		@bra:	Bracket
		@type:	Type
		@func:	Function
		@tmp:   StatementJump
		@dot:	PropertyOrAccess
		@acc:	PropertyOrAccess
		@brel:	brel
		@arel:	arel
		@rel:	Rel
		@list:	List
		@decl:	Declaration
		@arg:	Argument
		@sheb:  Ignore
		@sstr:	String
		@str:	String
		@num:	Number
		@char:	Char
		63:
			0     // for the size


	dispatch NilTmps (niltrackerfn)
		(asmtmp.kif):			If
		(asmtmp.kWhile):		While
		(asmtmp.kContinue):		Continue
		(asmtmp.kExit):			Exit
		(asmtmp.kReturn):		Return
		(asmtmp.kDebugger):		Debugger
		(asmtmp.kFail):			Fail
		(asmtmp.krejoin):		Rejoin
		63:
			0 // for size also

	
	TrackerDummies()
	function TrackerDummies
		for i in 64
			NilSyxes[i] := Dummy
			NilTmps[i] := Dummy



function Dummy (NilTrackerFn): debugger


function Ignore (NilTrackerFn)

		
function StatementJump (NilTrackerFn)
	return (NilTmps[msg.TmpType])(msg)


function Jump (NilTrackerFn)
	pragma inline
	return (NilSyxes[msg.func])(msg, test)

					
function UseChildAsReal (|message| msg, |NilState|) 	// a.b, *a, a[0], (a)()
	opt norefcounts
	|| dcl = msg.FastDecl
	if dcl is OnModule
		return dcl.NilDeclared
	|| ch = msg.first
		|| actual = .Jump(ch)
		if actual is nilish								// works e
			.BecomeReal(ch.FastDecl, ch)
		return dcl.nildeclared
	debugger // what?


function Rel (NilTrackerFn)
	if msg.TmpType is kSetVar							// x = y
		return SetRel(msg, test)
	return ProcessCondRel(msg, test)


function List (NilTrackerFn)
	opt norefcounts
	for s in msg
		.jump(s)
	return nilstate.Real


function PropertyOrAccess (NilTrackerFn)
	return .UseChildAsReal(msg)


function RealBool (|bool| b, |nilstate|)
	rz = nilstate.real
	rz |= nilstate.truevalue >> b


function Number (niltrackerfn)
	return .RealBool(msg.name.iszero)


function Char (niltrackerfn)
	return .RealBool(msg.name.isnull)


function String (niltrackerfn)
	return .RealBool(!msg.length)


function Function (NilTrackerFn)
	opt norefcounts
	test &=~ NilCheckMode.Disappears
	|| fp = msg.first
	|| prms = fp.next
	if msg.tmptype == ASMtmp.kTern
		return tern(prms, test)
	
	|| fn = prms.obj|SCFunction|
	if !fn
		expect (fp.func == @bra) (prms, errorreceiver.NonFatal)
		fn = fp.GetFunctionPointer
		require fn and .UseChildAsReal(fp)						// (abc)()
	
	expect ((fn != scfunction.currfunc) or t.RootReturned or t.nestdepth > 0) (msg, "Recursion bug. Sheesh.")
		
	fn.NilPrint(false)
	
	if (test is active) and fn.IsNilChecker
		Test |= NilCheckMode.Soft
		if t.FnAbleToNilCheck
			rz = nilstate.FnBecomesNilCh
	  else
		Test = 0
	
	|| P = prms.first
	|| HasAddrs = false
	for recv in fn.args
		if recv.nildeclare is optional
			test |= nilcheckmode.Soft
			
		|| v = .Jump(p, test)
		if rz and !(v is FnBecomesNilCh) and p.isfirst
			rz = 0 // can't work
		|| sent = p.FastDecl
		HasAddrs := sent.CanUpgradeInternalPointer
		if (v is nilish) and recv.NilReg	
			.NilParamPass(recv, sent, p, fn)

		Test = 0
		p++
	
	if HasAddrs
		p = prms.first
		for recv in fn.args
			|| infernal = p.FastDecl.CanUpgradeInternalPointer
				|| ri = recv.internal
				.VariableSet(infernal, recv.source, ri, p, ri.nilcurr)
			p++

	if fn.IsKiller
		.DeclKill
		return 0
	
	|| ret = fn.ReturnType
		rz |= ret.NilDeclared
		check ((rz is stated) or !ret.TypeSuffers) (msg, "Nil-decoration needed on return type of function: " + fn.RenderName)


function Rejoin (NilTrackerFn)
	opt norefcounts
	return .jump(msg.first!, Test) 


function DetectStillChecks (|message| first, |nilstate|)
	require first
	rz = .jump(first)
	if !t.FnAbleToNilCheck or (rz is FnBecomesNilCh)
		return rz

	|| F = first.TrueNess(rz)
	|| SelfNil = t.self is nilish 
	if f.isfalse
		if !SelfNil
			t.FnAbleToNilCheck = false		// also require that false returns ALWAYS have self nil!
		// optional is allowed to return false
	  elseif rz is FnBecomesNilCh			// its ok
		0
	  elseif SelfNil
		t.FnAbleToNilCheck = false			// Nilcheckers require only return true if self is not nil!


function Return (NilTrackerFn)
	opt norefcounts
	|| v = .DetectStillChecks(msg.first)
	.Loops.ExitRecord |= nilstate.Basic		// mark as exitting safely.
	.DeclKill
	|| ret = t.return
	if ret and ret.typesuffers
		if ret.isreal
			expect  (v isnt nilish)   (msg, "Declaration does not allow returning " + v.rawname)
		
		ret.NilDeclared = ret.nildeclared ||| (v&nilstate.either)					// assume real, unless it becomes optional??
		ret.NilPrint("return")


function Exit (NilTrackerFn)
	.loops.ExitRecord |= .EndBlock
	.loops.hasEscape = true


function Continue (NilTrackerFn)
	.loops.ContRecord |= .EndBlock


function WhileInner (|message| Cond)
	opt norefcounts
	//|nilrecord| OldCont // remove oldcont later, and lower loop count to 2

	for i in 3
		.jump(cond, NilCheckMode.whilepos)
		.Argument(cond.next)
		.Loops.NextLoop
		//if i == 1:    OldCont =  .Value // seems to change even after the second time?
		//if i == 2 and OldCont != .Value : debugat // Test the first two loops.
	

function While (NilTrackerFn)
	opt norefcounts
	|| cond = msg.first
	|| CondTest = cond.IsAlwaysBool

	require !CondTest.IsFalse and T.BranchEnter(msg)

	|| W = .loops.BeginLoop(!condtest.IsTrue)
	WhileInner(cond)
	if !condtest.IsTrue
		.jump(cond, NilCheckMode.whileneg)
		.loops.exitrecord |= .value // merge this
	
	.loops.FinishLoop(msg)
	ArchonPurger.loops = W

	return t.BranchExit
	


function If (NilTrackerFn)
	opt norefcounts
	|| Orig = T.BranchEnter(msg)				#require
	|| cond = msg.first,  || arg1 = cond.next
	|| Else = arg1.next,  || arg2 = else.first
	|| CondTrue = cond.IsAlwaysBool

	#!"First Branch"
	if !CondTrue.IsFalse		// ignore "if false: exit", for while-loops
		.Jump(Cond, NilCheckMode.positive)
		.Argument(arg1)
	
	|| First = T.BranchSwap(Orig)

	#!"Second Branch"
	if !CondTrue.istrue
		.jump(cond, NilCheckMode.negative) // we need the negative, for the merging.
		if arg2.HasAny
			( .Argument(arg2), .if(else) )(arg2.islast)
	
	return t.BranchExit(First)


function Tern (Niltrackerfn)
	opt norefcounts
	|| Orig = T.BranchEnter(msg)			#require
	|| tC = msg.first!,  || tA = tC.next!,  || tB = tA.next!

	#!"First Branch"
	.jump(tC, NilCheckMode.positive)
	rz = .Jump(tA, test)
	|| First = T.BranchSwap(Orig)

	#!"Second Branch"
	.jump(tC, nilcheckmode.negative)
	rz |= .Jump(tB, test)
	t.BranchExit(First)
	rz &= ~nilstate.FnBecomesNilCh	// in theory if BOTH were nil-testers... its OK
									// but thats sooo awkward to even think of a real-case
									// where I want this! Just don't do it!


function BooleanLogic (niltrackerfn)
	opt norefcounts
	|| AA = msg.first!
	|| BB = msg.last!
	|| IsAnd = test is AND
	(test is AND) = false 
	if IsAnd == (test is positive)
		|| NC = .Jump(AA, test)						// x = (!a or !a.y)
		NC   |= .Jump(BB, test)
		return nilstate.real ||| (NC & nilstate.FnBecomesNilCh)

	|| Orig = T.BranchEnter(AA)				#require
	
	#!"test A+"
	.Jump(AA, test)
	|| First = T.BranchSwap(Orig)

	#!"test A-B+"
	.Jump(AA, test.negate)
	.Jump(BB, test)

	return t.BranchExit(First)



function SuperSmartMagicCompare (|message| ll, |message| rr, |nilcheckmode| test, |scoperator| scop,   |nilstate|)
	opt norefcounts
	|| todo = 3
	if  ll.func == @thg and rr.func == @thg and test is Active
		if scop.IsEquals and (test is positive) == scop.IsExactlyEquals
		//	if real == x
		//		x becomes real
		// if real != x
		//     0
		//   else
		// 		x becomes real
			|| ld = ll.obj|scdecl|!
			|| rd = rr.obj|scdecl|!
			|| ldl = ld is local
			|| rdl = rd is Local
			if ldl or rdl
				if rdl and ld.NilCurr == NilState.Realish
					T.SetNilness(rd, NilState.real)
					todo &= ~2
				if ldl and rd.NilCurr == NilState.Realish
					T.SetNilness(ld, NilState.real)
					todo &= ~1
	
	if todo & 1
		.jump(ll, NilCheckMode.soft)
	if todo & 2	
		.jump(rr, NilCheckMode.soft)
	return nilstate.real


function CompareObjs (|message| ll, |message| rr, |nilcheckmode| test, |scoperator| scop,  |nilstate|)
	opt norefcounts
		
	|| LNil = ll.IsNowNil
	|| RNil = rr.IsNowNil
	if !lnil and !rnil			// if (a > b)
		return SuperSmartMagicCompare(ll, rr, test, scop)
	
	if (lnil and rnil)
		return ll.Redundant(ll.FastDecl, test)
	expect (scop.IsNilTest) (ll.next, "Nil can't accept this operator. Use != or ==.")
	
	(test is reversed) = scop.IsExactlyEquals
		
	|| side = (rr, ll)(lnil)
	return .jump(side, test.activate)  // can handle x = !(a == nil)


function ProcessCondRel (NilTrackerfn)
	opt norefcounts
	|| ll = msg.first
	|| op = ll.next
	|| rr = op.next
	|| scop = op.obj|SCOperator|

	if scop.IsCompare
		return .CompareObjs(ll, rr, test, scop)
	
	|| AndOr = scop.IsAndOr
		(test is AND) = (andor == scoperator.AND)
		return .BooleanLogic(msg, test.activate)

	|| L = .Jump(ll) & NilState.Either		// (ptr+1) or (1+ptr) still needs nilness check
	|| R = .Jump(rr) & NilState.Either
	if !msg.fastdecl.TypeSuffers			// (ptr-ptr) is actually a number... so thats OK.
		return nilstate.real
	if NilState.Nilish == l or r
		return nilstate.nilish
	return l ||| r



function Thing (NilTrackerFn)
	opt norefcounts
	|| dcl = msg.FastDecl
	rz = .ThingSub(msg, test, dcl)
	msg.Indent = rz				// The msg now knows the current state! Nice!
	if t.FnAbleToNilCheck and dcl is self
		rz |= nilstate.FnBecomesNilCh


function ThingSub (|message| msg,  |nilcheckmode| test,  |scdecl| dcl,  |nilstate|)
	opt norefcounts										// Handles 10 different cases :O

	if !dcl.NilReg
		return dcl.nildeclared
	
	|| Y = dcl.NilCurr
	|| Unknown = dcl.IsUnknownParam 
	if Unknown and (test isnt soft and disappears)
		if test isnt Active								// set var A to unknown prm B, so default to real
			return .BecomeReal(dcl, msg)
		dcl.NilDeclared = nilstate.optional

	if  test isnt active  or  test is soft and Negative
		return Y

	if Unknown or Y != test
		return T.SetNilness(dcl, Test)

	return msg.Redundant(dcl, test)



function Argument (Niltrackerfn)
	opt norefcounts
	|| v = .value.depthofvars + 1
	if v > 31 // hmm?
	for s.fast in msg
		s.DebugPrint
		|| t = test&-s.islast
		|| prev = rz
		rz = .jump(s, T ||| nilcheckmode.Disappears)
		if prev is borked
			error.autoprint = .oldprint
			expect !(stderr.ok) (s, "Borking but no zergs found?")
			stderr.clear
	
	|| Allowed = (1|uint64| << (v<<1)) - 1|uint64|
	t.setallnil(ArchonPurger.value & Allowed, "Argument")

	
function Bracket (Niltrackerfn)
	opt norefcounts
	if msg.length // a? --> (a) // but the bra has a name
		test |= NilCheckMode.Soft
	return .Jump((*msg)!, test)


function Type (Niltrackerfn)
	opt norefcounts
	|| F = msg.first!
	|| ns = .Jump(F, test) &~ nilstate.FnBecomesNilCh
	|| d = msg.FastDecl$
	if !d.TypeSuffers
		return nilstate.real
	|| fd = f.FastDecl
	if fd and fd.TypeSuffers // return inner suffering
		return ns
	
	return d.nildeclared // we created new suffering, so lets pass that back.


function Brel (Niltrackerfn)
	opt norefcounts
	|| b = msg.name.first
	if b == '*'
		return .UseChildAsReal(msg)							// *abc

	|| ch = *msg
	if b == '-' or '+' // for ++ or --
		return .jump(ch, test)
	if b == '!'
		return .Not(ch, test)
	
	.Jump(ch, test)
	return nilstate.real // & ~ both return real


function Not (niltrackerfn)
	test = (test ||| nilcheckmode.reversed).activate
	|| a = .jump(msg, test)
	return a &~ nilstate.FnBecomesNilCh


function arel (Niltrackerfn)
	opt norefcounts
	|| ch = *msg
		rz = .jump(ch, test)
		|| b = msg.name.first
		if b == '!'
//			expect (rz&nilstate.either != NilState.Nilish) (ch, "This value is known to be nil")
// what if it's later optional? or real? due to a loop... sigh.
			rz &=~ nilstate.nilish
			rz |=  nilstate.realish


// 
function Declaration (niltrackerfn) // function decl 
	opt norefcounts
	|| rel = msg.last
	if rel != @thg
		|| d = rel.first.FastDecl
		if d isnt body // what?
		if d.IsReg
			|| J = .Jump(rel.last)
			return T.Declare(D, J)


function SetRel (NilTrackerfn)
	opt norefcounts
	|| R = msg.last!
	|| L = msg.first!
	|| LD = L.FastDecl
	test = (nilcheckmode.soft) * (ld isnt local  and  ld.nildeclared == nilstate.optional)
	|| RN = .Jump(R, test)			// R is defined as coming first
	.Jump(L)
	return .VariableSet(LD, L, R.FastDecl, R, RN)


function Fail (NilTrackerFn)
	.OldPrint = error.autoprint 
	error.AutoPrint = 0
	return nilstate.borked


function Debugger (NilTrackerFn)
	// do nothing :)


function NilParamPass (|scdecl| Recv, |scdecl| Sent, |message| where, |scfunction| f)
	opt norefcounts
	if recv.isreal
		.BecomeReal(sent, where, f)
	  elseif !recv.nilstated and f != scfunction.currfunc  // haha
		recv.NilPrmFail(where, f)
	

function VariableSet (|scdecl| Recv, |message| RecvMsg, |scdecl| Sent, |message| SentMsg, |nilstate| SentState, |nilstate|) // setrel, relset
	opt norefcounts
	
	if !recv.typesuffers
		return nilstate.real
	expect (!recv.IsUnknownParam) (recvmsg, Recv.PrmStateMsg("Need to set it into another var."))

	if recv.isreal and recv isnt local
		if sentstate isnt nilish
			return sentstate
		expect (SentState is realish) (RecvMsg, "Nil is not allowed on: " + recvmsg.render)
		return .BecomeReal(sent, SentMsg)
		
	if recv.NilReg
		return T.SetNilness(recv, SentState)


function BecomeReal (|scdecl| sent, |message| where, |scfunction| To=nil,  |nilstate|)
	opt norefcounts
	|| Curr = sent.NilCurr
	if curr == NilState.Realish
		return curr
	
	if (Curr == nilstate.either) and sent.IsUnknownParam
		T.BecomeRealSub(sent)
		return T.SetNilness(sent, NilState.real)

	return .FailedReal(to, where)


function FailedReal (|scfunction| To, |message| where, |nilstate|)
	|| fs = faststring()
	fs <~ "NilObjectError "
	fs <~ ("passing optional param: ", "accessing optional: ")(to)
	where.render(fs)
	if To
		fs <~ " to "
		to.rendertitle(fs)
	error (where, fs)
}


function scdecl.IsUnknownParam (|bool|)
	pragma inline
	return (!.nilstated) and (self is param)


function message.Trueness (|nilstate| found, |maybebool|)
	opt norefcounts
	|| d = .FastDecl
	|| ret = ArchonPurger.t.return
	require d and ret // they are already real but the compiler will complain :[
	if d.FastMatch(ret)
		|| n = d.nildeclare
		if n & nilstate.KnownValue
			return n is TrueValue
		if found & nilstate.knownValue
			return found is TrueValue

	  elseif Ret.isdatatype and d.isdatatype // nothing special
		while self == @arg or @bra
			self = self.last
		|| rtf = ret.type.false
		if rtf and self and self matches rtf
			return false
	// return maybe

