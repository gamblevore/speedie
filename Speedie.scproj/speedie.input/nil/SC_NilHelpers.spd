

extend Message {

function Redundant (|nilstate| IsReal=nilstate.nilish, |nilcheckmode|)
	if StdErr.CanAddMore(errorseverity.problem)
		|| str = "Nil test is redundant on "
		str += isreal.name
		str += " object: "
		str += .render 
		StdErr.NewProblem(self, str)


function NilPropAccess (|bool|)
	opt norefcounts
	|| m = .DotMustBeProperty
		return m isnt onmodule


function NilDecl (|scdecl|)
	opt norefcounts
	if self
		|| obj = .obj as SCDecl // blindcast instead?
			|| l = obj.IsLookupOnly
			if l isa scdecl
				return l
			return obj
	

function LastInBlock
	opt norefcounts
	.RemoveAfter

	|| arg = .parent
	arg.flags |= kEndsBlock
	.Flags |= kEndsBlock
	|| Test = arg.parent
	require Test istmp "else" // this is really cool!

	while test
		arg = test.prev // if.arg
		require arg.Blocks
		test = arg.parent
		test.flags |= kEndsBlock
		if test.TmpType is kif
			return test.LastInBlock // bubble up :O
}


function scdecl.PointerUpgrade (|scdecl|)
	opt norefcounts
	|| infernal = .internal
	if (infernal Is Local) and infernal.SuffersNil
		return infernal


function @scfunction.LoopExitter (Tranfunc)
	|| f = node.first
		error f
	check node.FindOwningLoop(fn.sourcearg) (node, "Must be within a loop.")
	node.LastInBlock


function message.operatorvs (|message| arg2, |uint|)
	return .blocks (|) (arg2.blocks << 1)


function message.IsNowNil (|bool|)
	opt norefcounts
	|| d = .obj as scdecl
		return (d == TypeNil) or (d.NilCurr == nilstate.nilish)

function scdecl.SuffersNil (|bool|)
	return .IsObject or .PointerCount


function scdecl.NilStated (|bool|)
	return .NilDeclared is Stated


