

prototype NilTrackerFn (|message| msg, |NilCheckMode| Test=0,  |nilstate|)


datatype NilRecord (Uint64)
	linkage:cpp_part NRD

	syntax Access (|int| item, |nilstate|)
		item <<= 1
		return (self >> item) & NilState.either
		
	function Count (|uint|)
		return (.log2|uint|+1)>>1


struct NilRecorder
	linkage:cpp_part NRC
	|nilrecord| 	Value
	syntax call (|int| item, assigns:|nilstate| value)
		value &= nilstate.either
		item <<= 1
		|| Mask = NilState.either << item
		.value = (.value &~ Mask) ||| (value << item)
	syntax Call (|nilrecord| v, |nilrecord|)
		rz = .Value
		.Value = v


datatype NilCheckMode (uint)
	flags
		|NilCheckMode| 
		Nothing = 0
		Negative
		Positive
		Soft
		SoftPos = Positive + Soft  
		SoftNeg = Negative + Soft
		Active  = Positive + Negative

	syntax is (|NilCheckMode| other, |bool|)
		return self & other

	syntax isnt (|NilCheckMode| other, |bool|)
		return !(self & other)
	
	function Activate (|NilCheckmode|) 
		if (self isnt active)
			return self ||| nilcheckmode.positive
		return self
	
	function Negate (|NilCheckmode|)
		rz  = (self & negative) << 1
		rz |= (self & positive) >> 1
		rz |= (self &~ active)  << 0

