

/*
	NilTracker keeps track of a 3D-ish table. (2D + 2-layers)
	
	We have rows (declarations), columns (branch-depth), and each cell has two values for the two branch-side.
	
	We actually store it as bit-fields, but its still the same.
	
	Its a true work of art. Beyond which giants cannot compare.	
*/


struct LoopInfo 
	|NilRecord| 		ContRecord
	|NilRecord| 		ExitRecord
	|bool| 				HasEscape
	|int| 				Depth
	
	function Begin (|bool| HasEscape, |Loopinfo|)
		|| T = &ArchonPurger.T
		rz = *self
		.ExitRecord = 0
		.HasEscape = HasEscape
		.Contrecord = T.Place.value
		.Depth = T.CurrDepth

		if HasEscape
			.ExitRecord |= t.place.value
	
	function Finish (|message| msg)
		|| src = &ArchonPurger.T.loops
		|| Ex = src.ExitRecord					#check (msg, "Loop never exits.")
		if !src.HasEscape and !msg.islast
			msg.KinderRemoveAfter

		ArchonPurger.decls(Ex, "LoopEnd")
		ArchonPurger.T.loops = *self
	

struct ArchonPurger
	linkage: cpp_part nil
	|&NilRecord| 		Line
	|&NilRecord| 		RowEnd
	|Nilrecord| 		Realnesses
	target debug
		|Scdecl--[32]| 		Dbg
	|LoopInfo| 			Loops
	|NilRecord[64]| 	Rows
	
	function CurrDepth (|int|)
		return (.line - &.rows[0])|int|
	
	function DeclareReal (|scdecl| V)
		V.NilDeclared = NilState.real
		if .CurrDepth > 0		
			.Realnesses &= ~(nilstate.nilish << (V.NilReg<<1))
	
	function BranchEnter (|message| abc, |NilRecord|)
		if .line < .RowEnd
			|| N = *(.line++)
			*.line = N
			return N
		error (abc, "Branch depth too deep (over 63)")
	
	function BranchSwap (|NilRecord| A, |nilrecord|)
		rz = *.line
		.Set(A, "swap")
	
	function BranchExit (|NilRecord| A=0,  |nilstate|)
		|| B = *.line
		*.line-- = 0 // cleanup
		
		|| New = A ||| B
		new &= .Realnesses
		if .CurrDepth == 0
			.Realnesses = -1
		return .Set(New, "branchexit")

			
	function Declare (|scdecl| D, |nilstate| nd, |nilstate|)
		rz = .declaresub(d, nd)
		d.NilPrint("add")
	
	function DeclareSub (|scdecl| D, |nilstate| nd, |nilstate|)
		nd &= nilstate.either
		|| P = .Place
		|| N = p.value.NextCount
		expect (N < 31)								(D, "Too many declarations")
		(p)(n) = nd
		target debug
			ndb4()
		
		d.NilReg = N * d.Suffers
		if !d.suffers and d.nildeclare != nilstate.real
			
		d.DReg.Reg = n // right? might as well do this at the same time?
		d.NilAllocDepth = .currDepth
		target debug
			.dbg[n] = d
		if !d.nilcurr // bug!
		return nd
	
	function scdecl.NilCurr (|nilstate|)
		if self Isnt Local
			return .nildeclared &~ nilstate.stated
		return (ArchonPurger.place.Value)[.NilReg]
	
	
	function SetNilness (|SCDecl| d,  |NilState| New, |nilstate|)
		pragma inline
		if !d.nilreg or ((new&1) and (!d.suffers)) // WHA?
		|| P = .place
		(P)(d.NilReg) = new
		
		if (p.Value & .Realnesses)  !=  p.Value
			d.NilPrmFail
			
		d.NilPrint("set")
		return New

	function Start (|SCFunction| f, |message|)
		opt norefcounts
		require f.CanNil
		SCFunction.CurrFunc = f
		Phase = 1
		.rows[0] = nilstate.Basic
		.Line = .rows[0]
		.rowend = .line + 63
		.loops = nil
		.Realnesses = -1
		for d in f.args
			.DeclareSub(d, d.nildeclared)
		printline
		f.NilPrint(" ****** ")
		
		|| r = f.returntype
			if !r.nilstated
				r.nildeclared = 0 // build this up carefully.
		target debug: if "": ArchonPurger.ndb4(0)
		Phase = 2
		return f.SourceArg

	function Finish (|SCFunction| f)
		opt norefcounts
		phase = 3
		|| r = f.ReturnType
			r.nildeclared |= nilstate.stated
		for a in f.Args
			a.nildeclared |= nilstate.stated
		f.NilPrint(" !!!!! ")
	
	function Place (|&NilRecorder|)
		return (T.line)|&nilrecorder|

	function Decls (|string|s, |NilRecord| R)
		.place.Value = R

	module
		|ArchonPurger|	T
		|byte|			OldPrint
		|int|			Phase

		function Place (|&NilRecorder|)
			return (T.line)|&nilrecorder|
		
		function EndBlock (|nilrecord|)
			return (.place)(nilstate.basic)
	
		function Decls (|NilRecord| R, |string| s)
			.place.Value = R ||| nilstate.Basic

		function DeclKill
			t.set(0, "kill")
		

		function KhalaiPurification (|scfunction| f, |int| a)
			// it's like a protoss exterminating DA ZERGBUGZ 
			opt norefcounts
			require (a==1) == (f.cls ~= "niltest")
			|| arg = t.Start(f)
				Argument(arg)
				t.Finish(f)

		
		function PurgeArchons
			opt norefcounts
			require app["nil"].Yes

			using options.NilStrength		
			|| Rec = ErrorReceiver()
			using rec
				for f in compiler.funclist
					.KhalaiPurification(f, 1)
					rec.ReturnErrors
				for (f in compiler.funclist) (i)
					.KhalaiPurification(f, 2)
					"		Func: ${i+1} / ${compiler.funclist.length}"
					rec.ReturnErrors

			SCFunction.currfunc = nil
			StdErr.PrintErrors
