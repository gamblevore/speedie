

struct NilItem
	|scdecl--|		Decl
	|nilstate[2]|	New
	|uint16| 		PrevPos
	|nilstate|		Old
	|byte[3]| 		Dummy
	

	function Restore
		.decl.nilused = .old
	function Merge
		.decl.nilused = .new[0] (|) .new[1]



struct NilTracker
	linkage: cpp_part nil
	|scfunction--|		fn
	|uint| 				DeclCount
	|uint| 				CurrIf
	|NilItem[1536]|		Items



	function Restore (|nilsweep| sw, |nilstate|)
		for i in sw
			i.Restore
		return nilstate.realish
		
		
	function Restore (|uint| s, |bool| ChangeBack=false,  |nilstate|)
		|| f = .DeclCount
		if f > s
			if ChangeBack
				.DeclCount = f
			return .Restore(s sweep f)
		

	function MoveDown (|uint| s, |uint| f, |nilstate|)
		require f > s
		|| n = .declcount
		.DeclCount = s + (n-f)
		|| W = &.items[s]
		|| R = &.items[f]
		|| R2 = &.items[n]
		while R < R2
			*W++ = *R++

	function Merge (|uint| back)			// merges oldest values and newest values
		|| Range = (back sweep .DeclCount)
		for i in range
			i.merge

		
	function Pos (|scdecl| d, |&int| v,  |&NilItem|)		
		|| n = .DeclCount
		check (n < 1536) (.fn, "NilChecker got too many vars")
		.DeclCount = n + 1
		
		// we need to know where we are writign to
		// the info has to be here
		// how do we store this?
		// i guess just in one number... the best way
		return &.items[n]
	

	function SetNilness (|SCDecl| d, |NilState| s, |nilstate|)
		opt norefcounts
		|| old = d.nilused
		if  old > 3  or s > 3  or  d isnt local
		
		|| v = 0
		|| i = .Pos(d, v)
		i.Old = old
		i.New[v] = s
		i.new[1-v] = old
		i.decl = d
		d.nilused = s
		d.NilDebug("set")
		return s


	function Start (|scfunction| f)
		opt norefcounts
		scfunction.currfunc = f
		.DeclCount = 0
		.fn = f
		|| r = f.returntype
			r.NilUsed = 0 // :)


	function Finish (|scfunction| f)
		opt norefcounts
		f.ReturnType.DeclareAsUsed?
		.fn = nil
		
	
	function Check (|scfunction| f)
		opt norefcounts
		if platform.IsDebug
			.Start(f)
			f.nildebug
			Argument(f.SourceArg)
			.Finish(f)


	function scfunction.canNil (|bool|)
		return !.IsMacro and !.IsWrapper and .isOK and .LimitTests
	
	
	function scfunction.LimitTests (|bool|)
		|| c = .Lookup #require
		require c.name contains "NilTest"
		return .SourceArg contains "nilcheck"
	
	
	module
		|scdecl--|		CurrDecl
		|niltracker|	T
		function SaveLives
			opt norefcounts
			using options.NilStrength
				for f in compiler.funclist
					if f.cannil: T.Check(f)
				
			SCFunction.currfunc = nil
			StdErr.PrintErrors
			StdErr.Clear


function message.IsNowNil (|bool|)
	opt norefcounts
	|| d = .obj as scdecl
		return (d == TypeNil) or (d.nilused isnt real)


function SCDecl.DeclareAsUsed
	opt norefcounts
	.nildeclared = .NilUsed (|) nilstate.stated


function scdecl.SuffersNil (|bool|)
	return .IsObject or .PointerCount


function scdecl.NilStated (|bool|)
	return .NilDeclared is Stated


