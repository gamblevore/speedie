

/*
	NilTracker keeps track of a 3D-ish table. (2D + 2-layers)
	
	We have rows (declarations), columns (branch-depth), and each cell has two values for the two branch-side.
	
	We actually store it as bit-fields, but its still the same.
	
	Its a true work of art. Beyond which giants cannot compare.	
*/


struct LoopInfo 
	|NilRecord| 		ContRecord
	|NilRecord| 		ExitRecord
	|uint16| 			VarDepth
	|bool| 				HasEscape
	
	function BeginLoop (|bool| HasExitCond, |Loopinfo|)
		rz = *self
		|| v = ArchonPurger.value
		.ExitRecord = HasExitCond * V		// .Finish will check for non-zero
		.HasEscape = HasExitCond
		.ContRecord = V						// in case loop fails the first condition
		debugat
		.VarDepth = V.DepthOfVars
	
	
	function FinishLoop (|message| msg)
		|| Ex = .ExitRecord						#check (msg, "Loop never exits.")
		if !.HasEscape and !msg.islast
			msg.KinderRemoveAfter
		ArchonPurger.SetDirect(Ex, "LoopEnd")
	
	
	function NextLoop
		if scfunction.currfunc ~= "Exists7"
		|| Possi = (1|uint64| << (.VarDepth<<1)) - 1|uint64|
		Possi = (.ContRecord ||| ArchonPurger.value) & Possi
		.ContRecord = Possi
		archonpurger.SetDirect(Possi, "continue")
	
	

struct ArchonPurger
	linkage: cpp_part nil
	|&NilRecord| 			Neel
	|&NilRecord| 			RowEnd
	|Nilrecord| 			Realnesses
	target debug
		|Scdecl--[32]| 		Dbg
		|int|				MinDepth
	|scdecl|				Return
	|bool|					FnAbleToNilCheck
	|NilRecord[64]| 		Rows
	
	function NestDepth (|int|)
		return (.Neel - &.rows[0])|int|
	
	
	function DeclareReal (|scdecl| V)
		V.NilDeclared = NilState.real
		if v is self
			.FnAbleToNilCheck = false
		if .NestDepth > 0
			// The branch merger is not enough here. We need to affect the other branches.
			.Realnesses &= ~(nilstate.nilish << (V.NilReg<<1))
	
	
	function BranchEnter (|message| abc, |NilRecord|)
		if .Neel < .RowEnd
			|| N = *(.Neel++)
			*.Neel = N
			return N
		error (abc, "Branch depth too deep (over 63)")
	
	
	function BranchSwap (|NilRecord| A, |nilrecord|)
		rz = *.Neel
		.Set(A, "swap")
	
	
	function BranchExit (|NilRecord| A=0,  |nilstate|)
		|| B = *.Neel
		*.Neel-- = 0 // cleanup
		
		|| New = A ||| B
		new &= .Realnesses
		if .NestDepth == 0
			.Realnesses = -1
		return .Set(New, "branchexit")

			
	function Declare (|scdecl| D, |nilstate| nd, |nilstate|)
		rz = .declaresub(d, nd)
		d.NilPrint("add")
	
	
	function DeclareSub (|scdecl| D, |nilstate| nd, |nilstate|)
		nd &= nilstate.either
		|| P = (.Neel)|&nilrecorder|
		|| N = p.value.DepthOfVars
		expect (N < 31)								(D, "Too many declarations")
		target debug
			.dbg[n] = d
		d.NilReg = N * d.TypeSuffers			
		d.DReg.Reg = n // right? might as well do this at the same time?
		d.NilAllocDepth = .NestDepth
		(p)(n) = nd
		if !d.nilcurr // bug!
		return nd
	
	
	function scdecl.NilCurr (|nilstate|)
		if self Isnt Local
			return .nildeclared & nilstate.either
		return (ArchonPurger.Value)[.NilReg]
	
	
	function SetNilness (|SCDecl| d, |NilState| New, |NilState|)
		pragma inline
		if !d.nilreg or ((new&1) and (!d.TypeSuffers))  or  !New // WHA?
		|| P = (.Neel)|&nilrecorder|
		(P)(d.NilReg) = new
		
		if (p.Value & .Realnesses)  !=  p.Value
			// this might not be a param fail... it could just be an internal fail??
			
		d.NilPrint("set")
		return New


	function StartNil (|SCFunction| f, |message|)
		opt norefcounts
		require f.CanNil

		SCFunction.CurrFunc = f
		.rows[0] = nilstate.Basic
		.Neel = .rows[0]
		.rowend = .Neel + 63
		archonpurger.loops = nil
		.Realnesses = -1
		.CheckNilCheck(F)
		
		for d in f.args
			.DeclareSub(d, d.nildeclared)
		target debug
			.MinDepth = value().DepthOfVars
		printline
		f.NilPrint(" ****** ", false)
		
		|| r = f.returntype
			if !r.nilstated
				r.nildeclared = 0 // build this up carefully.
		target debug: if "": ArchonPurger.ndb4
		return f.SourceArg


	function Finish (|SCFunction| f)
		opt norefcounts
		if .FnAbleToNilCheck
			f.isnilchecker = true
		|| r = f.ReturnType
			r.nildeclared |= nilstate.stated
		for a in f.Args
			a.nildeclared |= nilstate.stated
		f.NilPrint(" !!!!! ", true)
	

	function CheckNilCheck (|SCFunction| f)
		opt norefcounts
		.FnAbleToNilCheck = false
		.return = f.returntype
		|| s = f.args.first
			if (s.nildeclared is nilish) and s.TypeSuffers and .return.CanNilCheck
				.FnAbleToNilCheck = true


	function Self (|nilstate|)
		return (*t.Neel)[1]


	module
		|LoopInfo| 				Loops
		|ArchonPurger|	T
		|byte|			OldPrint

		function Value (|NilRecord|)
			return *T.Neel
			
		function EndBlock (|nilrecord|)
			return .SetDirect(nilstate.basic, "blockend")
	
		function SetDirect (|NilRecord| R, |string| s, |nilrecord|)
			rz = (T.Neel|&nilrecorder|)(R)
			target debug
				if t.mindepth > rz.DepthOfVars

		function DeclKill
			t.set(nilstate.Basic, "kill")
		

		function KhalaiPurification (|scfunction| f, |int| a)
			// it's like a protoss exterminating DA ZERGBUGZ 
			opt norefcounts
			require (a==1) == (f.cls ~= "niltest")
			|| arg = t.Startnil(f)
				Argument(arg)
				t.Finish(f)

		
		function FixArchons
			opt norefcounts
			require app["nil"].Yes

			using options.NilStrength		
			|| Rec = ErrorReceiver()
			using rec
				for f in compiler.funclist
					.KhalaiPurification(f, 1)
					rec.ReturnErrors
				for (f in compiler.funclist) (i)
					.KhalaiPurification(f, 2)
					"		Func: ${i+1} / ${compiler.funclist.length}"
					rec.ReturnErrors

			SCFunction.currfunc = nil
			StdErr.PrintErrors
