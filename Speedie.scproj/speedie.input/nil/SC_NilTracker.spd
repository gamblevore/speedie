
struct NilTracker
	linkage: cpp_part nil
	|byte| 				DeclCount
	|byte| 				BranchDepth
	|bool| 				BranchSide
	|uint| 				ChangeTracker
	|NilDecl[31]| 		Rows


	function Restore (|uint| sw, |nilstate|)
		debugger 
//		for i in sw
//			i.Restore
		return nilstate.realish
		
		
	function Restore (|bool| s,  |nilstate|)
		debugger 
//		|| f = .DeclCount
//		if f > s
//			return .Restore(s sweep f)
		

	function MoveDown (|uint| s, |uint| f, |nilstate|)
		debugger 
		require f > s
//		|| n = .DeclCount
//		.DeclCount = s + (n-f)
//		|| W = &.resets[s]
//		|| R = &.resets[f]
//		|| R2 = &.resets[n]
//		while R < R2
//			*W++ = *R++


	function Merge (|uint| back)			// merges oldest values and newest values
		debugger 
//		|| Range = (back sweep .DeclCount)
//		for i in range
//			i.merge


	function BranchExit (|uint| OldDecls, |nilstate|)
		debugger 
		.branchdepth--
//		|| sw = olddecls sweep .DeclCount
//		for i in sw
//			i.decl.NilPlace = i.PrevPos
	
	
	function BranchEnter (|uint|)
		rz = .DeclCount
		.branchdepth++


	function AddDecl (|scdecl| d)
		|| n = .DeclCount++
		|| i = .rows[n]
		i.AllocDepth = .BranchDepth
		i.ID = n
		i.Decl = d
		d.nil = i.Record
		debug_require d.SuffersNil and n <= 31
	
	
	function SetNilness (|SCDecl| d, |NilState| New, |nilstate|)
		opt norefcounts			// combine these into one number... later. If we want.	
		d.nil[.branchdepth].Side[.BranchSide] = New
		d.NilCurr = new
		d.NilPrint("set")
		return New
		

	function Start (|scfunction| f)
		opt norefcounts
		.DeclCount = 0
		.BranchDepth = 0
		for d in f.args
			.AddDecl(d)
			.SetNilness(d, d.NilDeclared&nilstate.either)
		f.NilPrint


	function Finish (|scfunction| f)
		opt norefcounts
		|| r = f.ReturnType
			r.nildeclared |= nilstate.stated
		f.NilPrint
	
	
	function NilCheck (|scfunction| f)
		opt norefcounts
		if platform.IsDebug
			.Start(f)
			debugger 
			Argument(f.SourceArg)
			.Finish(f)


	function scfunction.CanNil (|bool|)
		return !.IsMacro and !.IsWrapper and .isOK and .LimitTests
	
	
	function scfunction.LimitTests (|bool|)
		|| c = .Lookup #require
		require c.name contains "NilTest"
		return .SourceArg contains "nilcheck"
	
	
	module
		|NilTracker|	T

		function SaveLives
			opt norefcounts
			for f in compiler.funclist
				SCFunction.CurrFunc = f
				f.CheckNilDepth
				if f.CanNil
					T.NilCheck(f)
		
			.cleanup


		function Cleanup
			MaxNilDepth.Report("depth")
			MaxNilObjs.Report("objs")
			SCFunction.currfunc = nil
			StdErr.PrintErrors
			StdErr.Clear
