

/*
	NilTracker keeps track of a 3D-ish table. (2D + 2-layers)
	
	We have rows (declarations), columns (branch-depth), and each cell has two values for the two branch-side.
	
	We actually store it as bit-fields, but its still the same.
	
	Its a true work of art. Beyond which giants cannot compare.	
*/


struct LoopInfo 
	|NilRecord| 		ContRecord
	|NilRecord| 		ExitRecord
	|byte| 				VarCount
	|byte| 				NestDepth
	|bool| 				HasEscape
	
	function BeginLoop (|bool| HasExitCond, |Loopinfo|)
		rz = *self
		|| v = ArchonPurger.value
		target debug
			if  ArchonPurger.t.mindepth > v.DepthOfVars
		
		.ExitRecord = HasExitCond|nilrecord| * V	// .Finish will check for non-zero
		.HasEscape = HasExitCond
		.ContRecord = V								// in case loop fails the first condition
		.VarCount = V.DepthOfVars
		.NestDepth = ArchonPurger.t.nestdepth
	
	
	function FinishLoop (|message| msg)
		|| Ex = .ExitRecord						#check (msg, "Loop never exits.")
		if !.HasEscape and !msg.islast
			msg.KinderRemoveAfter
		ArchonPurger.t.SetAllNil(Ex, "LoopEnd")
	
	
	function NextLoop 
		.ContRecord |= ArchonPurger.value
		ArchonPurger.t.SetAllNil(.contrecord, "continue")


	

struct ArchonPurger
	linkage: cpp_part nil
	|&NilRecord| 			Neel
	|&NilRecord| 			RowEnd
	|Nilrecord| 			Realnesses
	target debug
		|Scdecl--[32]| 		Dbg
		|int|				MinDepth
	|scdecl?|				Return
	|bool|					FnAbleToNilCheck
	|bool| 					RootReturned // for recursive funcs
	|NilRecord[64]| 		Rows
	
	
	function NestDepth (|int|)
		return (.Neel - &.rows[0])|int|
	
	
	function BecomeRealSub (|scdecl| V)
		V.NilDeclared = NilState.real
		if v is self
			.FnAbleToNilCheck = false
		if .NestDepth > 0 // We need to affect the other branches.
			.Realnesses &= ~(nilstate.nilish << (V.NilReg<<1))
	
	
	function BranchEnter (|message| where, |NilRecord|)
		expect (.Neel < .RowEnd) (where, "Branch depth too deep (over 63)")
		rz = *(.Neel++)
		.setallnil(rz, "BranchEnter")
	
	
	function BranchSwap (|NilRecord| A, |nilrecord|)
		rz = value()
		.SetAllNil(A, "swap")
	
	
	function BranchExit (|NilRecord| A=0,  |nilstate|)
		|| B = value()
		*.Neel-- = 0 // cleanup
		
		.SetAllNil(A ||| B, "BranchExit")
		if .NestDepth == 0
			.Realnesses = -1
		return nilstate.real

			
	function Declare (|scdecl| D, |nilstate| nd, |nilstate|)
		rz = .declaresub(d, nd)
		d.NilPrint("add")
	
	
	function DeclareSub (|scdecl| D, |nilstate| nd, |nilstate|)
		nd &= nilstate.either
		|| N = .value.DepthOfVars + 1
		expect (N < 31)								(D, "Too many declarations")
		target debug
			.dbg[n] = d
		d.NilReg = N * d.TypeSuffers			
		d.DReg.Reg = n // right? might as well do this at the same time?
		d.NilAllocDepth = .NestDepth
		|| P = (.Neel)|&nilrecorder| // setset
		(p)(n) = nd
		return nd
	
	
	function scdecl.NilCurr (|nilstate|)
		if self Isnt Local
			return .nildeclared & nilstate.either
		return (ArchonPurger.Value)[.NilReg]
	
	
	function SetNilness (|SCDecl| d, |NilState| New, |NilState|)
		pragma inline
		|| P = (.Neel)|&nilrecorder| // setset
		(P)(d.NilReg) = new
		d.NilPrint("set")
		if d ~= "debug"
		return New


	function StartNil (|SCFunction| f, |message|)
		opt norefcounts
		require f.CanNil

		SCFunction.CurrFunc = f
		.rows[0] = nilstate.Basic
		.Neel = .rows[0]
		.rowend = .Neel + 63
		ArchonPurger.loops = nil
		.Realnesses = -1
		.RootReturned = false
		.CheckNilCheck(F)
		
		for d in f.args
			.DeclareSub(d, d.nildeclared)
		target debug
			.MinDepth = value().DepthOfVars
		printline
		f.NilPrint(" ****** ", false)
		
		|| r = f.ReturnType
			if !r.nilstated
				r.nildeclared = 0 // build this up carefully.
		target debug: if "": ArchonPurger.ndb4
		return f.SourceArg


	function FinishNil (|SCFunction| f)
		opt norefcounts
		|| r = f.ReturnType
			r.nildeclared |= nilstate.stated
		for a in f.Args
			a.nildeclared |= nilstate.stated
		f.NilPrint(" !!!!! ", true)
	

	function CheckNilCheck (|SCFunction| f)
		opt norefcounts
		.FnAbleToNilCheck = false
		.return = f.returntype
		|| s = f.args.first
			if (s.nildeclared is nilish) and s.TypeSuffers and .return.CanNilCheck
				.FnAbleToNilCheck = true


	function Value (|nilrecord|)
		pragma inline
		opt norefcounts
		rz = *.Neel
		|| d = rz.depthofvars
			target debug
				if (d > 24) or !.dbg[d]
	
	
	function Self (|nilstate|)
		return (.value)[1]


	function SetAllNil (|NilRecord| Dest, |string| reason)
		|| DDDD = Dest
		dest &= .Realnesses
		
		target debug {
			if  t.mindepth > dest.DepthOfVars  and  dest != nilstate.basic
			|| diff = dest xor value()
		} else {
			pragma inline
		}

		.value
		*.neel = dest // setset
		if Dest & (3|uint64| << 62|uint64|)
		.value
		
		target debug {
			for i in 32
				|| d = .dbg[i]
				if d and diff[i]
					d.nilprint(reason)
		}


	module
		|LoopInfo| 				Loops
		|ArchonPurger|			T
		|byte|					OldPrint


		function Value (|NilRecord|)
			pragma inline
			return t.value


		function EndBlock (|nilrecord|)
			pragma inline
			rz = .value
			t.SetAllNil(nilstate.basic, "blockend")


		function DeclKill
			pragma inline
			t.RootReturned = true
			t.SetAllNil(nilstate.Basic, "kill")
		

		function KhalaiPurification (|scfunction| f, |int| a)
			// it's like a protoss exterminating DA ZERGBUGZ 
			opt norefcounts
			require (a==1) == (f.cls ~= "niltest")
			|| arg = t.Startnil(f)
				Argument(arg)
				if t.FnAbleToNilCheck
					f.isnilchecker = true
			t.FinishNil(f)

		
		function FixArchons
			opt norefcounts
			require app["nil"].Yes

			using options.NilStrength		
			|| Rec = ErrorReceiver()
			using rec
				for f in compiler.funclist
					.KhalaiPurification(f, 1)
					rec.ReturnErrors
				for (f in compiler.funclist) (i)
					errorreceiver.progress = i+1
					.KhalaiPurification(f, 2)
					"		Func: ${errorreceiver.progress} / ${compiler.funclist.length}"
					rec.ReturnErrors

			SCFunction.currfunc = nil
			StdErr.PrintErrors
