

datatype NilState (byte) // Exec.scproj needs this here
	constants
		|nilstate|
		Failed		= 0
		Nilish		= 1
		Realish		= 2
		Either		= 3
		Stated		= 4
		ActuallyNil = Nilish  + Stated
		Optional    = Either  + Stated
		Real		= Realish + Stated
		Basic		= Realish
		Borked		= 128
	
	function Worst (|nilstate| o, |nilstate|)
		rz = self ||| o
		if rz is Nilish
			rz = Nilish
	
	function RawName (|string|)
		description "'Raw', cos does not include whether its stated or not." 
		if self is either
			return "optional"
		if self is nilish
			return "nil"
		if self is realish
			return "real"
		return "lost"
		
	syntax is (|nilstate| type, |bool|)
		return (self & type) == type
	syntax isnt (|nilstate| type, |bool|)
		return !.SyntaxIs(type)
	


struct ASMVarType
	contains object
	|int|					Contains // also a class
	|int|					ClassNum
	|int|					C_Array
	|byte|					PointerCount
	|NilState|				Expected
	|NilState|				Found

