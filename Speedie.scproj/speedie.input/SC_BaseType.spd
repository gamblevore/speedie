


datatype SCBaseType (byte)
	constants (
		|SCBaseType|
		Module = 0 // not actually a type
		Nil
		DataType
		FuncProto
		Struct
		Object
	)
	syntax is (|scbasetype| d, |bool|)
		return self == d


extend scclass
	function IsStruct (|bool|)
		return .BaseType == SCBaseType.struct
	
	function IsDataTypeOnly (|bool|)
		return .BaseType == SCBaseType.datatype
	
	function IsDataTypeOrFP (|bool|)
		return .BaseType == SCBaseType.datatype or SCBaseType.funcproto
	

	syntax equals (|SCBaseType| d, |bool| aware, |bool|)
		cpp_part EqualsType
		if self and d > SCBaseType.nil
			return .BaseType == d
